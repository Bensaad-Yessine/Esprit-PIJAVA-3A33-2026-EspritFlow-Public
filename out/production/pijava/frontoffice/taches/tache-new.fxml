<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>
<?import javafx.collections.FXCollections?>

<?import java.lang.String?>
<HBox xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
      stylesheets="@tache-new.css"
      fx:controller="piJava.Controllers.frontoffice.taches.TacheNewController"
      styleClass="root-bg" prefWidth="1100" prefHeight="800">
    <ScrollPane fitToWidth="true" styleClass="page-scroll" HBox.hgrow="ALWAYS">
        <VBox spacing="26" styleClass="main-container">

            <!-- HEADER -->
            <HBox alignment="CENTER_LEFT" spacing="20">
                <VBox HBox.hgrow="ALWAYS" spacing="6">
                    <Label text="Nouvelle tâche" styleClass="title"/>
                    <Label text="ESPRIT Flow · Créer une tâche académique" styleClass="subtitle"/>
                </VBox>
            </HBox>

            <!-- Form Card -->
            <VBox spacing="24" styleClass="form-card">

                <!-- Title -->
                <VBox spacing="8" GridPane.columnIndex="0" GridPane.rowIndex="0" GridPane.columnSpan="2">
                    <Label text="Titre *" styleClass="field-label"/>
                    <TextField fx:id="txtTitre" promptText="Titre de la tâche" styleClass="form-field"/>
                </VBox>

                <!-- Type -->
                <VBox spacing="8" GridPane.columnIndex="0" GridPane.rowIndex="0" GridPane.columnSpan="2">
                    <Label text="Type *" styleClass="field-label"/>
                    <ComboBox fx:id="cbType" styleClass="form-field">
                        <items>
                            <FXCollections fx:factory="observableArrayList">
                                <String fx:value="MANUEL"/>
                                <String fx:value="REVISION"/>
                                <String fx:value="REUNION"/>
                                <String fx:value="EMPLOI"/>
                                <String fx:value="SANTE"/>
                            </FXCollections>
                        </items>
                    </ComboBox>
                </VBox>


                <!-- Date & Time Start -->
                <VBox spacing="8" GridPane.columnIndex="0" GridPane.rowIndex="2">
                    <Label text="Date de début *" styleClass="field-label"/>
                    <DatePicker fx:id="dpDateDebut" promptText="jj/mm/aaaa" styleClass="date-picker"/>
                </VBox>

                <VBox spacing="8" GridPane.columnIndex="1" GridPane.rowIndex="2">
                    <Label text="Heure de début" styleClass="field-label"/>
                    <TextField fx:id="txtHeureDebut" promptText="HH:mm:ss" styleClass="form-field"/>
                </VBox>

                <!-- Date & Time End -->
                <VBox spacing="8" GridPane.columnIndex="0" GridPane.rowIndex="3">
                    <Label text="Date de fin *" styleClass="field-label"/>
                    <DatePicker fx:id="dpDateFin" promptText="jj/mm/aaaa" styleClass="date-picker"/>
                </VBox>

                <VBox spacing="8" GridPane.columnIndex="1" GridPane.rowIndex="3">
                    <Label text="Heure de fin" styleClass="field-label"/>
                    <TextField fx:id="txtHeureFin" promptText="HH:mm:ss" styleClass="form-field"/>
                </VBox>

                <!-- Priority -->
                <VBox spacing="8" GridPane.columnIndex="0" GridPane.rowIndex="0" GridPane.columnSpan="2">
                    <Label text="Priority *" styleClass="field-label"/>
                    <ComboBox fx:id="cbPriorite" styleClass="form-field">
                        <items>
                            <FXCollections fx:factory="observableArrayList">
                                <String fx:value="ELEVEE"/>
                                <String fx:value="MOYEN"/>
                                <String fx:value="FAIBLE"/>
                            </FXCollections>
                        </items>
                    </ComboBox>
                </VBox>

                <!-- Status -->
                <VBox spacing="8" GridPane.columnIndex="1" GridPane.rowIndex="3">
                    <Label text="Status" styleClass="field-label"/>
                    <ComboBox fx:id="cbStatut" styleClass="form-field">
                        <items>
                            <FXCollections fx:factory="observableArrayList">
                                <String fx:value="EN_COURS"/>
                                <String fx:value="A_FAIRE"/>
                                <String fx:value="PAUSED"/>
                                <String fx:value="TERMINEE"/>
                            </FXCollections>
                        </items>
                    </ComboBox>
                </VBox>

                <!-- Description -->
                <VBox spacing="8" GridPane.columnIndex="0" GridPane.rowIndex="5" GridPane.columnSpan="2">
                    <Label text="Description" styleClass="field-label"/>
                    <TextArea fx:id="txtDescription" promptText="Description de la tâche" styleClass="form-field" prefRowCount="3"/>
                </VBox>

                <!-- Duration -->
                <VBox spacing="8" GridPane.columnIndex="0" GridPane.rowIndex="6">
                    <Label text="Durée estimée (minutes)" styleClass="field-label"/>
                    <TextField fx:id="txtDuree" styleClass="form-field"/>
                </VBox>

                <!-- Notification -->
                <Label fx:id="lblNotification" GridPane.columnIndex="0" GridPane.rowIndex="7" GridPane.columnSpan="2" styleClass="notification"/>

                <!-- Buttons -->
                <HBox spacing="15" GridPane.columnIndex="0" GridPane.rowIndex="8" GridPane.columnSpan="2" alignment="CENTER_RIGHT">
                    <Button text="Ajouter" onAction="#handleAdd" styleClass="btn-primary"/>
                </HBox>

            </VBox>

        </VBox>
    </ScrollPane>
</HBox>