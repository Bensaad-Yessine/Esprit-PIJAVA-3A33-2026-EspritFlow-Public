<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.collections.FXCollections?>
<?import java.lang.String?>

<HBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="piJava.Controllers.frontoffice.taches.TacheEditController"
      stylesheets="@tache-edit.css"
      styleClass="root-bg" prefWidth="1100" prefHeight="800">

    <ScrollPane fitToWidth="true" styleClass="page-scroll" HBox.hgrow="ALWAYS">
        <VBox spacing="26" styleClass="main-container">

            <!-- HEADER -->
            <HBox alignment="CENTER_LEFT" spacing="20">
                <VBox HBox.hgrow="ALWAYS" spacing="6">
                    <Label text="✏️ Modifier la tâche" styleClass="title"/>
                    <Label text="ESPRIT Flow · Modifier une tâche académique" styleClass="subtitle"/>
                </VBox>
            </HBox>

            <!-- FORM CARD -->
            <VBox spacing="24" styleClass="form-card">

                <!-- Title -->
                <VBox spacing="8">
                    <Label text="Titre *" styleClass="field-label"/>
                    <TextField fx:id="txtTitre" promptText="Titre de la tâche" styleClass="form-field"/>
                </VBox>

                <!-- Type -->
                <VBox spacing="8">
                    <Label text="Type *" styleClass="field-label"/>
                    <ComboBox fx:id="cbType" maxWidth="Infinity" styleClass="form-field">
                        <items>
                            <FXCollections fx:factory="observableArrayList">
                                <String fx:value="MANUEL"/>
                                <String fx:value="REVISION"/>
                                <String fx:value="REUNION"/>
                                <String fx:value="EMPLOI"/>
                                <String fx:value="SANTE"/>
                            </FXCollections>
                        </items>
                    </ComboBox>
                </VBox>

                <!-- Dates row -->
                <HBox spacing="20">
                    <VBox spacing="8" HBox.hgrow="ALWAYS">
                        <Label text="Date de début *" styleClass="field-label"/>
                        <DatePicker fx:id="dpDateDebut" styleClass="date-picker"/>
                    </VBox>
                    <VBox spacing="8" HBox.hgrow="ALWAYS">
                        <Label text="Heure de début (HH:mm)" styleClass="field-label"/>
                        <TextField fx:id="txtHeureDebut" promptText="00:00" styleClass="form-field"/>
                    </VBox>
                    <VBox spacing="8" HBox.hgrow="ALWAYS">
                        <Label text="Date de fin *" styleClass="field-label"/>
                        <DatePicker fx:id="dpDateFin" styleClass="date-picker"/>
                    </VBox>
                    <VBox spacing="8" HBox.hgrow="ALWAYS">
                        <Label text="Heure de fin (HH:mm)" styleClass="field-label"/>
                        <TextField fx:id="txtHeureFin" promptText="23:59" styleClass="form-field"/>
                    </VBox>
                </HBox>

                <!-- Priority + Status row -->
                <HBox spacing="20">
                    <VBox spacing="8" HBox.hgrow="ALWAYS">
                        <Label text="Priorité *" styleClass="field-label"/>
                        <ComboBox fx:id="cbPriorite" maxWidth="Infinity" styleClass="form-field">
                            <items>
                                <FXCollections fx:factory="observableArrayList">
                                    <String fx:value="HAUTE"/>
                                    <String fx:value="MOYENNE"/>
                                    <String fx:value="BASSE"/>
                                </FXCollections>
                            </items>
                        </ComboBox>
                    </VBox>
                    <VBox spacing="8" HBox.hgrow="ALWAYS">
                        <Label text="Statut" styleClass="field-label"/>
                        <ComboBox fx:id="cbStatut" maxWidth="Infinity" styleClass="form-field">
                            <items>
                                <FXCollections fx:factory="observableArrayList">
                                    <String fx:value="A_FAIRE"/>
                                    <String fx:value="EN_COURS"/>
                                    <String fx:value="PAUSED"/>
                                    <String fx:value="TERMINE"/>
                                    <String fx:value="ABANDON"/>
                                </FXCollections>
                            </items>
                        </ComboBox>
                    </VBox>
                </HBox>

                <!-- Description -->
                <VBox spacing="8">
                    <Label text="Description" styleClass="field-label"/>
                    <TextArea fx:id="txtDescription" promptText="Description de la tâche"
                              styleClass="form-field" prefRowCount="3"/>
                </VBox>

                <!-- Duration -->
                <VBox spacing="8">
                    <Label text="Durée estimée (minutes)" styleClass="field-label"/>
                    <TextField fx:id="txtDuree" promptText="ex: 60" styleClass="form-field"/>
                </VBox>

                <!-- Notification -->
                <Label fx:id="lblNotification" styleClass="notification-label"/>

                <!-- Buttons -->
                <HBox spacing="12" alignment="CENTER_RIGHT">
                    <Button text="Annuler"       onAction="#handleCancel" styleClass="btn-secondary"/>
                    <Button text="Enregistrer"   onAction="#handleSave"   styleClass="btn-primary"/>
                </HBox>

            </VBox>
        </VBox>
    </ScrollPane>
</HBox>
