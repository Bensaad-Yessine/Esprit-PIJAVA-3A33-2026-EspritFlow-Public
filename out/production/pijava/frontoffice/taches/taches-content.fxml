<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>

<?import javafx.collections.FXCollections?>
<?import java.lang.String?>
<HBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="piJava.Controllers.frontoffice.taches.TachesController"
      stylesheets="@taches.css"
      prefWidth="1500" prefHeight="900"
      styleClass="root-bg">
    <ScrollPane fitToWidth="true" styleClass="page-scroll" HBox.hgrow="ALWAYS">
        <VBox spacing="26" styleClass="main-container">

            <!-- HEADER -->
            <HBox alignment="CENTER_LEFT" spacing="20">
                <VBox HBox.hgrow="ALWAYS" spacing="6">
                    <Label text="Mes Tâches" styleClass="title"/>
                    <Label text="ESPRIT Flow · Gestion de tâches académiques" styleClass="subtitle"/>
                </VBox>
                <Button fx:id="btnNewTask" text="＋ Nouvelle tâche" onAction="#addTask" styleClass="btn-primary"/>

            </HBox>

            <Label fx:id="notificationLabel" text="" styleClass="notification-label"/>

            <!-- 4 STAT CARDS -->
            <HBox spacing="20">

                <VBox HBox.hgrow="ALWAYS" prefHeight="140"
                      spacing="8" alignment="TOP_LEFT"
                      styleClass="red-card">
                    <Label text="📋  Total Tâches" styleClass="card-label"/>
                    <Label fx:id="lblTotalTasks" text="42" styleClass="card-number"/>
                    <Label text="Toutes catégories" styleClass="card-sub"/>
                </VBox>

                <VBox HBox.hgrow="ALWAYS" prefHeight="140"
                      spacing="8" alignment="TOP_LEFT"
                      styleClass="red-card-light">
                    <Label text="⏳  En cours" styleClass="card-label"/>
                    <Label fx:id="lblInProgress" text="18" styleClass="card-number"/>
                    <Label text="À compléter" styleClass="card-sub"/>
                </VBox>

                <VBox HBox.hgrow="ALWAYS" prefHeight="140"
                      spacing="8" alignment="TOP_LEFT"
                      styleClass="red-card-mid">
                    <Label text="✅  Terminées" styleClass="card-label"/>
                    <Label fx:id="lblCompleted" text="20" styleClass="card-number"/>
                    <Label text="Ce mois-ci" styleClass="card-sub"/>
                </VBox>

                <VBox HBox.hgrow="ALWAYS" prefHeight="140"
                      spacing="8" alignment="TOP_LEFT"
                      styleClass="red-card-soft">
                    <Label text="🔥  Urgentes" styleClass="card-label"/>
                    <Label fx:id="lblUrgent" text="4" styleClass="card-number"/>
                    <Label text="Échéance proche" styleClass="card-sub"/>
                </VBox>

            </HBox>

            <!-- FILTERS & SORT CARD - IMPROVED -->
            <HBox spacing="20" styleClass="filter-card">
                <VBox spacing="8" HBox.hgrow="ALWAYS">
                    <Label text="🔍 Rechercher" styleClass="filter-label"/>
                    <TextField fx:id="txtSearch" promptText="Nom de la tâche..." styleClass="search-field"/>
                </VBox>

                <VBox spacing="8" prefWidth="200">
                    <Label text="🏷️ Statut" styleClass="filter-label"/>
                    <ComboBox fx:id="cmbStatus" prefWidth="200" styleClass="filter-combo" promptText="Tous les statuts">
                        <items>
                            <FXCollections fx:factory="observableArrayList">
                                <String fx:value="Tous"/>
                                <String fx:value="À faire"/>
                                <String fx:value="En cours"/>
                                <String fx:value="Terminée"/>
                                <String fx:value="En retard"/>
                                <String fx:value="Abandonnée"/>
                            </FXCollections>
                        </items>
                    </ComboBox>
                </VBox>

                <VBox spacing="8" prefWidth="200">
                    <Label text="⚡ Priorité" styleClass="filter-label"/>
                    <ComboBox fx:id="cmbPriority" prefWidth="200" styleClass="filter-combo" promptText="Toutes priorités">
                        <items>
                            <FXCollections fx:factory="observableArrayList">
                                <String fx:value="Toutes"/>
                                <String fx:value="Haute"/>
                                <String fx:value="Moyenne"/>
                                <String fx:value="Basse"/>
                            </FXCollections>
                        </items>
                    </ComboBox>
                </VBox>

                <VBox spacing="8" prefWidth="200">
                    <Label text="📅 Trier par" styleClass="filter-label"/>
                    <ComboBox fx:id="cmbSort" prefWidth="200" styleClass="filter-combo" promptText="Date de création">
                        <items>
                            <FXCollections fx:factory="observableArrayList">
                                <String fx:value="Date de création"/>
                                <String fx:value="Date d'échéance"/>
                                <String fx:value="Priorité"/>
                                <String fx:value="Nom (A-Z)"/>
                            </FXCollections>
                        </items>
                    </ComboBox>
                </VBox>

                <VBox spacing="8" alignment="BOTTOM_CENTER">
                    <Label text=" " styleClass="filter-label"/>
                    <Button fx:id="btnResetFilters" text="⟲ Réinitialiser" styleClass="btn-reset"/>
                </VBox>

            </HBox>

            <!-- Active Tasks Section -->
            <VBox spacing="12">
                <HBox alignment="CENTER_LEFT" spacing="12">
                    <Label text="📌 Tâches actives" styleClass="panel-title" HBox.hgrow="ALWAYS"/>
                    <Label fx:id="lblActiveCount" text="0 actives" styleClass="task-count"/>
                </HBox>

                <ScrollPane fitToWidth="true" styleClass="task-scroll" prefHeight="400">
                    <VBox fx:id="activeTasksContainer" spacing="16" styleClass="tasks-container"/>
                </ScrollPane>
            </VBox>

            <!-- Separator -->
            <HBox spacing="16" alignment="CENTER" styleClass="section-separator">
                <Separator orientation="HORIZONTAL" HBox.hgrow="ALWAYS" styleClass="separator-line"/>
                <Label text="📦 Archivées" styleClass="separator-text"/>
                <Separator orientation="HORIZONTAL" HBox.hgrow="ALWAYS" styleClass="separator-line"/>
            </HBox>

            <!-- Archived Tasks Section -->
            <VBox spacing="12">
                <HBox alignment="CENTER_LEFT" spacing="12">
                    <Label text="📦 Tâches archivées" styleClass="panel-title" HBox.hgrow="ALWAYS"/>
                    <Label fx:id="lblArchivedCount" text="0 archivées" styleClass="task-count-archived"/>
                </HBox>

                <ScrollPane fitToWidth="true" styleClass="task-scroll" prefHeight="400">
                    <VBox fx:id="archivedTasksContainer" spacing="16" styleClass="tasks-container"/>
                </ScrollPane>
            </VBox>


        </VBox>
    </ScrollPane>

</HBox>