<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="piJava.Controllers.frontoffice.preferencealerte.AlerteDetailsController"
      stylesheets="@alerte-details.css"
      styleClass="main-container"
      spacing="24">

    <!-- HEADER -->
    <HBox alignment="CENTER_LEFT" spacing="16">
        <Button text="← Retour" onAction="#handleBack" styleClass="btn-back"/>
        <VBox spacing="4" HBox.hgrow="ALWAYS">
            <Label text="Détails de la préférence" styleClass="title"/>
            <Label text="EspritFlow · Informations complètes" styleClass="subtitle"/>
        </VBox>
    </HBox>

    <!-- INFO CARD -->
    <VBox styleClass="info-card" spacing="20">

        <Label text="Informations générales" styleClass="section-title"/>

        <GridPane hgap="24" vgap="16">
            <columnConstraints>
                <ColumnConstraints percentWidth="50"/>
                <ColumnConstraints percentWidth="50"/>
            </columnConstraints>

            <VBox spacing="6" GridPane.columnIndex="0" GridPane.rowIndex="0">
                <Label text="NOM" styleClass="field-label"/>
                <Label fx:id="lblNom" styleClass="field-value"/>
            </VBox>

            <VBox spacing="6" GridPane.columnIndex="1" GridPane.rowIndex="0">
                <Label text="STATUT" styleClass="field-label"/>
                <Label fx:id="lblActive" styleClass="badge"/>
            </VBox>

            <VBox spacing="6" GridPane.columnIndex="0" GridPane.rowIndex="1">
                <Label text="PAR DÉFAUT" styleClass="field-label"/>
                <Label fx:id="lblDefault" styleClass="field-value"/>
            </VBox>

            <VBox spacing="6" GridPane.columnIndex="1" GridPane.rowIndex="1">
                <Label text="DÉLAI DE RAPPEL" styleClass="field-label"/>
                <Label fx:id="lblDelai" styleClass="field-value"/>
            </VBox>
        </GridPane>

        <Label text="Canaux de notification" styleClass="section-title"/>

        <GridPane hgap="24" vgap="16">
            <columnConstraints>
                <ColumnConstraints percentWidth="33"/>
                <ColumnConstraints percentWidth="33"/>
                <ColumnConstraints percentWidth="33"/>
            </columnConstraints>

            <VBox spacing="6" GridPane.columnIndex="0" GridPane.rowIndex="0">
                <Label text="📧 EMAIL" styleClass="field-label"/>
                <Label fx:id="lblEmail" styleClass="field-value"/>
            </VBox>

            <VBox spacing="6" GridPane.columnIndex="1" GridPane.rowIndex="0">
                <Label text="🔔 PUSH" styleClass="field-label"/>
                <Label fx:id="lblPush" styleClass="field-value"/>
            </VBox>

            <VBox spacing="6" GridPane.columnIndex="2" GridPane.rowIndex="0">
                <Label text="🌐 SITE" styleClass="field-label"/>
                <Label fx:id="lblSite" styleClass="field-value"/>
            </VBox>
        </GridPane>

        <Label text="Heures de silence" styleClass="section-title"/>

        <HBox spacing="40">
            <VBox spacing="6">
                <Label text="DÉBUT" styleClass="field-label"/>
                <Label fx:id="lblSilenceDebut" styleClass="field-value"/>
            </VBox>
            <VBox spacing="6">
                <Label text="FIN" styleClass="field-label"/>
                <Label fx:id="lblSilenceFin" styleClass="field-value"/>
            </VBox>
        </HBox>

    </VBox>

</VBox>
