<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.*?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="piJava.Controllers.backoffice.Matiere.MatiereContentController"
      styleClass="main-content"
      spacing="24"
      stylesheets="@matieres.css">

    <!-- ── Header ─────────────────────────────────────────── -->
    <HBox alignment="CENTER_LEFT" spacing="16" styleClass="page-header">
        <VBox HBox.hgrow="ALWAYS" spacing="4">
            <HBox alignment="CENTER_LEFT" spacing="8">
                <Label text="Backoffice" styleClass="breadcrumb-inactive"/>
                <Label text="›" styleClass="breadcrumb-sep"/>
                <Label text="Gestion des Matières" styleClass="breadcrumb-active"/>
            </HBox>
            <Label text="Gestion des Matières" styleClass="page-title"/>
        </VBox>
        <TextField fx:id="searchField"
                   promptText="🔍  Rechercher une matière..."
                   styleClass="search-bar"/>
        <Button fx:id="addMatiereBtn" text="＋  Nouvelle Matière"
                styleClass="btn-add" onAction="#handleAdd"/>
    </HBox>

    <!-- ── Mini Stats ─────────────────────────────────────── -->
    <HBox spacing="16" styleClass="mini-stats" alignment="CENTER_LEFT">

        <HBox styleClass="mini-stat" spacing="10" alignment="CENTER_LEFT">
            <Label text="📖" styleClass="mini-stat-icon"/>
            <VBox spacing="2">
                <Label fx:id="totalMatieresLabel" text="—" styleClass="mini-stat-number"/>
                <Label text="Total Matières" styleClass="mini-stat-label"/>
            </VBox>
        </HBox>

        <Region styleClass="mini-stat-divider" prefWidth="1" prefHeight="40"/>

        <HBox styleClass="mini-stat" spacing="10" alignment="CENTER_LEFT">
            <Label text="⚖️" styleClass="mini-stat-icon"/>
            <VBox spacing="2">
                <Label fx:id="avgCoeffLabel" text="—" styleClass="mini-stat-number"/>
                <Label text="Coeff. moyen" styleClass="mini-stat-label"/>
            </VBox>
        </HBox>

        <Region styleClass="mini-stat-divider" prefWidth="1" prefHeight="40"/>

        <HBox styleClass="mini-stat" spacing="10" alignment="CENTER_LEFT">
            <Label text="⏱" styleClass="mini-stat-icon"/>
            <VBox spacing="2">
                <Label fx:id="totalHeuresLabel" text="—" styleClass="mini-stat-number"/>
                <Label text="Total heures" styleClass="mini-stat-label"/>
            </VBox>
        </HBox>

        <Region styleClass="mini-stat-divider" prefWidth="1" prefHeight="40"/>

        <HBox styleClass="mini-stat" spacing="10" alignment="CENTER_LEFT">
            <Label text="🔥" styleClass="mini-stat-icon"/>
            <VBox spacing="2">
                <Label fx:id="avgComplexiteLabel" text="—" styleClass="mini-stat-number"/>
                <Label text="Complexité moy." styleClass="mini-stat-label"/>
            </VBox>
        </HBox>

    </HBox>

    <!-- ── Filter Bar ─────────────────────────────────────── -->
    <HBox spacing="10" styleClass="filter-bar" alignment="CENTER_LEFT">
        <Label text="Filtrer :" styleClass="filter-label"/>
        <ComboBox fx:id="coeffFilter"     promptText="Coefficient"  styleClass="filter-combo"/>
        <ComboBox fx:id="complexiteFilter" promptText="Complexité"  styleClass="filter-combo"/>
        <Button fx:id="resetFilterBtn" text="✕  Réinitialiser"
                styleClass="btn-reset" onAction="#handleResetFilters"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Label fx:id="resultCountLabel" text="0 résultats" styleClass="result-count"/>
    </HBox>

    <!-- ── Table Panel ────────────────────────────────────── -->
    <VBox styleClass="table-panel" VBox.vgrow="ALWAYS">

        <TableView fx:id="matiereTable" styleClass="matiere-table" VBox.vgrow="ALWAYS">
            <columns>
                <TableColumn fx:id="idCol"         text="#"             prefWidth="55"/>
                <TableColumn fx:id="nomCol"         text="NOM"          prefWidth="220"/>
                <TableColumn fx:id="coeffCol"       text="COEFFICIENT"  prefWidth="130"/>
                <TableColumn fx:id="heuresCol"      text="HEURES"       prefWidth="110"/>
                <TableColumn fx:id="complexiteCol"  text="COMPLEXITÉ"   prefWidth="120"/>
                <TableColumn fx:id="descCol"        text="DESCRIPTION"  prefWidth="240"/>
                <TableColumn fx:id="actionsCol"     text="ACTIONS"      prefWidth="180"/>
            </columns>
            <placeholder>
                <VBox alignment="CENTER" spacing="12" styleClass="empty-state">
                    <Label text="📖" styleClass="empty-icon"/>
                    <Label text="Aucune matière trouvée" styleClass="empty-title"/>
                    <Label text="Cliquez sur « Nouvelle Matière » pour commencer"
                           styleClass="empty-sub"/>
                </VBox>
            </placeholder>
        </TableView>

        <!-- Footer -->
        <HBox styleClass="table-footer" alignment="CENTER_LEFT" spacing="16">
            <Label fx:id="footerLabel" text="Affichage de 0 entrées" styleClass="footer-text"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Button fx:id="prevBtn"  text="‹" styleClass="page-btn" onAction="#handlePrev"/>
            <Label  fx:id="pageLabel" text="1" styleClass="page-current"/>
            <Button fx:id="nextBtn"  text="›" styleClass="page-btn" onAction="#handleNext"/>
        </HBox>

    </VBox>

</VBox>
