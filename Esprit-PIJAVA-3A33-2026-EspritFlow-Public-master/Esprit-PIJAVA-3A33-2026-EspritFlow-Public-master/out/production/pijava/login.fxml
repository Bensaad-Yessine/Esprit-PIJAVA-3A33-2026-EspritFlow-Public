<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.Hyperlink?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.Region?>

<AnchorPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="piJava.Controllers.loginController"
            prefHeight="700.0" prefWidth="1000.0"
            stylesheets="@login.css"
            styleClass="root-pane">

    <!-- Left branding panel -->
    <VBox alignment="CENTER" layoutX="0" layoutY="0"
          prefWidth="460" prefHeight="700"
          styleClass="brand-panel">
        <padding><Insets left="70" right="50"/></padding>

        <!-- Logo mark -->
        <HBox alignment="CENTER_LEFT" spacing="12">
            <StackPane prefWidth="42" prefHeight="42" styleClass="logo-box">
                <Label text="E" styleClass="logo-letter"/>
            </StackPane>
            <Label text="EspritFlow" styleClass="logo-name"/>
            <VBox.margin><Insets bottom="48"/></VBox.margin>
        </HBox>

        <!-- Headline -->
        <Label text="Welcome back."
               styleClass="headline">
            <VBox.margin><Insets bottom="12"/></VBox.margin>
        </Label>
        <Label text="Your learning journey continues here."
               styleClass="subheadline" wrapText="true">
            <VBox.margin><Insets bottom="48"/></VBox.margin>
        </Label>

        <!-- Feature pills -->
        <VBox spacing="14">
            <HBox spacing="12" alignment="CENTER_LEFT">
                <StackPane prefWidth="32" prefHeight="32" styleClass="feature-icon">
                    <Label text="✦" styleClass="feature-icon-blue"/>
                </StackPane>
                <Label text="Smart class scheduling &amp; tracking"
                       styleClass="feature-text"/>
            </HBox>
            <HBox spacing="12" alignment="CENTER_LEFT">
                <StackPane prefWidth="32" prefHeight="32" styleClass="feature-icon">
                    <Label text="◈" styleClass="feature-icon-indigo"/>
                </StackPane>
                <Label text="Real-time collaboration with peers"
                       styleClass="feature-text"/>
            </HBox>
            <HBox spacing="12" alignment="CENTER_LEFT">
                <StackPane prefWidth="32" prefHeight="32" styleClass="feature-icon">
                    <Label text="⬡" styleClass="feature-icon-red"/>
                </StackPane>
                <Label text="Secure &amp; verified student accounts"
                       styleClass="feature-text"/>
            </HBox>
        </VBox>

    </VBox>

    <!-- Divider -->
    <Region layoutX="460" layoutY="60" prefWidth="1" prefHeight="580"
            styleClass="divider"/>

    <!-- Right login card -->
    <VBox alignment="TOP_LEFT"
          layoutX="500" layoutY="60"
          prefWidth="430"
          styleClass="login-card">

        <!-- Card header -->
        <Label text="Sign in"
               styleClass="card-title">
            <VBox.margin><Insets bottom="4"/></VBox.margin>
        </Label>
        <Label text="Enter your credentials to access your account"
               styleClass="card-subtitle">
            <VBox.margin><Insets bottom="28"/></VBox.margin>
        </Label>

        <!-- Email -->
        <Label text="Email address" styleClass="field-label">
            <VBox.margin><Insets bottom="6"/></VBox.margin>
        </Label>
        <TextField fx:id="emailField"
                   promptText="you@esprit.tn"
                   styleClass="input-field">
            <VBox.margin><Insets bottom="18"/></VBox.margin>
        </TextField>

        <!-- Password -->
        <Label text="Password" styleClass="field-label">
            <VBox.margin><Insets bottom="6"/></VBox.margin>
        </Label>
        <PasswordField fx:id="passwordField"
                       promptText="••••••••"
                       styleClass="input-field">
            <VBox.margin><Insets bottom="14"/></VBox.margin>
        </PasswordField>

        <!-- Remember me + Forgot -->
        <HBox alignment="CENTER_LEFT" spacing="8">
            <CheckBox fx:id="rememberMeCheck"
                      text="Remember me"
                      styleClass="remember-check"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Hyperlink text="Forgot password?"
                       onAction="#handleForgotPassword"
                       styleClass="link-blue"/>
            <VBox.margin><Insets bottom="22"/></VBox.margin>
        </HBox>

        <!-- Login button -->
        <Button text="Sign in to EspritFlow"
                maxWidth="Infinity"
                onAction="#handleLogin"
                styleClass="btn-primary">
            <VBox.margin><Insets bottom="12"/></VBox.margin>
        </Button>

        <!-- Gmail button -->
        <Button text="Continue with Gmail"
                maxWidth="Infinity"
                onAction="#handleGmailLogin"
                styleClass="btn-outline">
            <VBox.margin><Insets bottom="12"/></VBox.margin>
        </Button>

        <!-- FaceID button -->
        <Button text="Login with FaceID"
                maxWidth="Infinity"
                onAction="#handleFaceID"
                styleClass="btn-ghost">
            <VBox.margin><Insets bottom="24"/></VBox.margin>
        </Button>

        <!-- Divider -->
        <HBox alignment="CENTER" spacing="10">
            <Separator HBox.hgrow="ALWAYS" styleClass="sep"/>
            <Label text="or" styleClass="sep-label"/>
            <Separator HBox.hgrow="ALWAYS" styleClass="sep"/>
            <VBox.margin><Insets bottom="16"/></VBox.margin>
        </HBox>

        <!-- Sign up row -->
        <HBox alignment="CENTER" spacing="6">
            <Label text="Don't have an account?" styleClass="muted-text"/>
            <Hyperlink text="Create one free →"
                       onAction="#handleSignUp"
                       styleClass="link-blue-bold"/>
        </HBox>

    </VBox>

</AnchorPane>
