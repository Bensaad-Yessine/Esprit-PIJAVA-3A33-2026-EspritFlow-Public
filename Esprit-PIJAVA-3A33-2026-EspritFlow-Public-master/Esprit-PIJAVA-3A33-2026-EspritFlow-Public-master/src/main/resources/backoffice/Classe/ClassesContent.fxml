<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.*?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="piJava.Controllers.backoffice.Classe.ClasseContentController"
      styleClass="main-content"
      spacing="24"
      stylesheets="@classes.css">

    <!-- ── Header ─────────────────────────────────────────── -->
    <HBox alignment="CENTER_LEFT" spacing="16" styleClass="page-header">
        <VBox HBox.hgrow="ALWAYS" spacing="4">
            <HBox alignment="CENTER_LEFT" spacing="8">
                <Label text="Backoffice" styleClass="breadcrumb-inactive"/>
                <Label text="›" styleClass="breadcrumb-sep"/>
                <Label text="Gestion des Classes" styleClass="breadcrumb-active"/>
            </HBox>
            <Label text="Gestion des Classes" styleClass="page-title"/>
        </VBox>
        <TextField fx:id="searchField"
                   promptText="🔍  Rechercher une classe..."
                   styleClass="search-bar"/>
        <Button fx:id="addClasseBtn" text="＋  Nouvelle Classe"
                styleClass="btn-add" onAction="#handleAdd"/>
    </HBox>

    <!-- ── Mini Stats ─────────────────────────────────────── -->
    <HBox spacing="16" styleClass="mini-stats" alignment="CENTER_LEFT">

        <HBox styleClass="mini-stat" spacing="10" alignment="CENTER_LEFT">
            <Label text="🏫" styleClass="mini-stat-icon"/>
            <VBox spacing="2">
                <Label fx:id="totalClassesLabel" text="—" styleClass="mini-stat-number"/>
                <Label text="Total Classes" styleClass="mini-stat-label"/>
            </VBox>
        </HBox>

        <!-- Use Region instead of Rectangle — Rectangle.maxWidth is read-only in FXML -->
        <Region styleClass="mini-stat-divider" prefWidth="1" prefHeight="40"/>

        <HBox styleClass="mini-stat" spacing="10" alignment="CENTER_LEFT">
            <Label text="📐" styleClass="mini-stat-icon"/>
            <VBox spacing="2">
                <Label fx:id="niveauxLabel" text="—" styleClass="mini-stat-number"/>
                <Label text="Niveaux" styleClass="mini-stat-label"/>
            </VBox>
        </HBox>

        <Region styleClass="mini-stat-divider" prefWidth="1" prefHeight="40"/>

        <HBox styleClass="mini-stat" spacing="10" alignment="CENTER_LEFT">
            <Label text="🎯" styleClass="mini-stat-icon"/>
            <VBox spacing="2">
                <Label fx:id="filieresLabel" text="—" styleClass="mini-stat-number"/>
                <Label text="Filières" styleClass="mini-stat-label"/>
            </VBox>
        </HBox>

        <Region styleClass="mini-stat-divider" prefWidth="1" prefHeight="40"/>

        <HBox styleClass="mini-stat" spacing="10" alignment="CENTER_LEFT">
            <Label text="📅" styleClass="mini-stat-icon"/>
            <VBox spacing="2">
                <Label fx:id="anneeLabel" text="2024–2025" styleClass="mini-stat-number"/>
                <Label text="Année universitaire" styleClass="mini-stat-label"/>
            </VBox>
        </HBox>

    </HBox>

    <!-- ── Filter Bar ─────────────────────────────────────── -->
    <HBox spacing="10" styleClass="filter-bar" alignment="CENTER_LEFT">
        <Label text="Filtrer :" styleClass="filter-label"/>
        <ComboBox fx:id="niveauFilter"  promptText="Niveau"      styleClass="filter-combo"/>
        <ComboBox fx:id="filiereFilter" promptText="Filière"     styleClass="filter-combo"/>
        <ComboBox fx:id="anneeFilter"   promptText="Année univ." styleClass="filter-combo"/>
        <Button fx:id="resetFilterBtn" text="✕  Réinitialiser"
                styleClass="btn-reset" onAction="#handleResetFilters"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Label fx:id="resultCountLabel" text="0 résultats" styleClass="result-count"/>
    </HBox>

    <!-- ── Table Panel ────────────────────────────────────── -->
    <VBox styleClass="table-panel" VBox.vgrow="ALWAYS">

        <TableView fx:id="classeTable" styleClass="classe-table" VBox.vgrow="ALWAYS">
            <columns>
                <TableColumn fx:id="idCol"      text="#"                prefWidth="55"/>
                <TableColumn fx:id="nomCol"     text="NOM DE LA CLASSE" prefWidth="200"/>
                <TableColumn fx:id="niveauCol"  text="NIVEAU"           prefWidth="120"/>
                <TableColumn fx:id="filiereCol" text="FILIÈRE"          prefWidth="160"/>
                <TableColumn fx:id="anneeCol"   text="ANNÉE UNIV."      prefWidth="140"/>
                <TableColumn fx:id="descCol"    text="DESCRIPTION"      prefWidth="220"/>
                <TableColumn fx:id="actionsCol" text="ACTIONS"          prefWidth="180"/>
            </columns>
            <placeholder>
                <VBox alignment="CENTER" spacing="12" styleClass="empty-state">
                    <Label text="🏫" styleClass="empty-icon"/>
                    <Label text="Aucune classe trouvée" styleClass="empty-title"/>
                    <Label text="Cliquez sur « Nouvelle Classe » pour commencer"
                           styleClass="empty-sub"/>
                </VBox>
            </placeholder>
        </TableView>

        <!-- Footer -->
        <HBox styleClass="table-footer" alignment="CENTER_LEFT" spacing="16">
            <Label fx:id="footerLabel" text="Affichage de 0 entrées" styleClass="footer-text"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Button fx:id="prevBtn"  text="‹" styleClass="page-btn" onAction="#handlePrev"/>
            <Label  fx:id="pageLabel" text="1" styleClass="page-current"/>
            <Button fx:id="nextBtn"  text="›" styleClass="page-btn" onAction="#handleNext"/>
        </HBox>

    </VBox>

</VBox>
