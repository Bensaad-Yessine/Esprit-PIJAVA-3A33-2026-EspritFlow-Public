<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.shape.*?>
<?import javafx.geometry.*?>
<?import javafx.scene.text.*?>

<ScrollPane fitToWidth="true"
            xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="piJava.Controllers.frontoffice.user.profileController"
            style="-fx-background-color: #F0F4F8; -fx-background: #F0F4F8;"
            prefWidth="860.0" prefHeight="650.0">

    <VBox spacing="0" style="-fx-background-color: #F0F4F8;">

        <!-- ═══════════════ HERO HEADER BANNER ═══════════════ -->
        <StackPane prefHeight="200">
            <!-- Gradient Banner -->
            <Pane style="-fx-background-color: linear-gradient(to right, #B71C1C, #C62828, #D32F2F, #EF5350);"
                  prefHeight="200" prefWidth="860"/>

            <!-- Decorative circles -->
            <Circle radius="120" style="-fx-fill: rgba(255,255,255,0.05);"
                    translateX="-280" translateY="-30"/>
            <Circle radius="80" style="-fx-fill: rgba(255,255,255,0.05);"
                    translateX="300" translateY="40"/>
            <Circle radius="50" style="-fx-fill: rgba(255,255,255,0.08);"
                    translateX="150" translateY="-60"/>

            <!-- Avatar + name overlay at bottom -->
            <HBox alignment="BOTTOM_LEFT" style="-fx-padding: 0 0 16 40;">
                <!-- Avatar circle -->
                <StackPane onMouseClicked="#handleEditAvatar" style="-fx-cursor: hand;">
                    <Circle fx:id="avatarCircle" radius="56"
                            style="-fx-fill: white; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.35), 12, 0, 0, 4);"/>
                    <Label fx:id="avatarInitials"
                           text="AB"
                           style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: #C62828; -fx-font-family: 'Georgia';"/>
                    <!-- Edit avatar button -->
                    <StackPane alignment="BOTTOM_RIGHT" translateX="16" translateY="16">
                        <Circle radius="14" style="-fx-fill: #E53935; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.3), 4, 0, 0, 2);"/>
                        <Label text="✎" style="-fx-font-size: 12px; -fx-text-fill: white;"/>
                    </StackPane>
                </StackPane>

                <!-- Name & role -->
                <VBox spacing="2" style="-fx-padding: 0 0 8 16;" alignment="BOTTOM_LEFT">
                    <Label fx:id="lblFullName" text="Prénom Nom"
                           style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: white; -fx-font-family: 'Georgia';"/>
                    <HBox spacing="8" alignment="CENTER_LEFT">
                        <Label fx:id="lblRole"
                               style="-fx-background-color: rgba(255,255,255,0.2); -fx-background-radius: 20; -fx-text-fill: #E8EAF6; -fx-font-size: 11px; -fx-padding: 3 10;"/>
                        <Label fx:id="lblVerified" text="✔ Vérifié"
                               style="-fx-background-color: rgba(76,175,80,0.3);
              -fx-background-radius: 20;
              -fx-text-fill: #C8E6C9;
              -fx-font-size: 11px;
              -fx-padding: 3 10;"/>
                    </HBox>
                </VBox>
            </HBox>
        </StackPane>

        <!-- ═══════════════ STATUS BAR ═══════════════ -->
        <HBox fx:id="banBadge" spacing="8" alignment="CENTER"
              style="-fx-background-color: #B71C1C; -fx-padding: 8; -fx-max-height: 0; -fx-opacity: 0;">
            <Label text="🚫" style="-fx-font-size: 14px;"/>
            <Label text="Compte suspendu ·" style="-fx-text-fill: white; -fx-font-weight: bold;"/>
            <Label fx:id="lblBanReason" style="-fx-text-fill: #FFCDD2; -fx-font-size: 12px;"/>
        </HBox>

        <!-- ═══════════════ MAIN CONTENT ═══════════════ -->
        <HBox spacing="20" style="-fx-padding: 24 32;">

            <!-- LEFT COLUMN: Stats + Quick Info -->
            <VBox spacing="16" prefWidth="240" minWidth="200">

                <!-- Stats Card -->
                <VBox style="-fx-background-color: white; -fx-background-radius: 16; -fx-padding: 20; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.08), 10, 0, 0, 2);">
                    <Label text="STATISTIQUES" style="-fx-font-size: 10px; -fx-font-weight: bold; -fx-text-fill: #9E9E9E; -fx-padding: 0 0 12 0;"/>

                    <HBox alignment="CENTER" spacing="0" style="-fx-padding: 0 0 16 0;">
                        <!-- Stat: Joined -->
                        <VBox alignment="CENTER" HBox.hgrow="ALWAYS">
                            <Label fx:id="lblJoinYear" text="2024"
                                   style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #C62828; -fx-font-family: 'Georgia';"/>
                            <Label text="Membre depuis" style="-fx-font-size: 10px; -fx-text-fill: #9E9E9E;"/>
                        </VBox>
                        <Separator orientation="VERTICAL" prefHeight="40"/>
                        <!-- Stat: Class -->
                        <VBox alignment="CENTER" HBox.hgrow="ALWAYS">
                            <Label fx:id="lblClasseStat" text="—"
                                   style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #C62828; -fx-font-family: 'Georgia';"/>
                            <Label text="Classe" style="-fx-font-size: 10px; -fx-text-fill: #9E9E9E;"/>
                        </VBox>
                    </HBox>

                    <Separator style="-fx-opacity: 0.3;"/>

                    <!-- Quick info rows -->
                    <VBox spacing="10" style="-fx-padding: 12 0 0 0;">
                        <HBox spacing="10" alignment="CENTER_LEFT">
                            <Label text="📧" style="-fx-font-size: 13px;"/>
                            <Label fx:id="lblEmailSmall" text="email@example.com"
                                   style="-fx-font-size: 11px; -fx-text-fill: #616161; -fx-wrap-text: true;" maxWidth="160"/>
                        </HBox>
                        <HBox spacing="10" alignment="CENTER_LEFT">
                            <Label text="📱" style="-fx-font-size: 13px;"/>
                            <Label fx:id="lblTelSmall" text="+216 XX XXX XXX"
                                   style="-fx-font-size: 11px; -fx-text-fill: #616161;"/>
                        </HBox>
                        <HBox spacing="10" alignment="CENTER_LEFT">
                            <Label text="🎂" style="-fx-font-size: 13px;"/>
                            <Label fx:id="lblDobSmall" text="—"
                                   style="-fx-font-size: 11px; -fx-text-fill: #616161;"/>
                        </HBox>
                        <HBox spacing="10" alignment="CENTER_LEFT">
                            <Label text="⚥" style="-fx-font-size: 13px;"/>
                            <Label fx:id="lblSexeSmall" text="—"
                                   style="-fx-font-size: 11px; -fx-text-fill: #616161;"/>
                        </HBox>
                    </VBox>
                </VBox>

                <!-- Change Password Card -->
                <VBox spacing="10"
                      style="-fx-background-color: white; -fx-background-radius: 16; -fx-padding: 20; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.08), 10, 0, 0, 2);">
                    <Label text="MOT DE PASSE" style="-fx-font-size: 10px; -fx-font-weight: bold; -fx-text-fill: #9E9E9E;"/>
                    <PasswordField fx:id="pfNewPassword" promptText="Nouveau mot de passe"
                                   style="-fx-background-color: #FFF5F5; -fx-background-radius: 8; -fx-padding: 8 12; -fx-font-size: 12px; -fx-border-color: #FFCDD2;"/>
                    <PasswordField fx:id="pfConfirmPassword" promptText="Confirmer le mot de passe"
                                   style="-fx-background-color: #FFF5F5; -fx-background-radius: 8; -fx-padding: 8 12; -fx-font-size: 12px; -fx-border-color: #FFCDD2;"/>
                    <Button fx:id="btnChangePassword" text="Mettre à jour"
                            onAction="#handleChangePassword"
                            style="-fx-background-color: #C62828; -fx-text-fill: white; -fx-font-size: 12px; -fx-background-radius: 8; -fx-padding: 8 16; -fx-cursor: hand;"
                            maxWidth="Infinity"/>
                    <Label fx:id="lblPasswordMsg" text="" wrapText="true"
                           style="-fx-font-size: 11px; -fx-text-fill: #4CAF50;"/>
                </VBox>

            </VBox>

            <!-- RIGHT COLUMN: Edit Form -->
            <VBox spacing="16" HBox.hgrow="ALWAYS">

                <!-- Personal Info Card -->
                <VBox spacing="0"
                      style="-fx-background-color: white; -fx-background-radius: 16; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.08), 10, 0, 0, 2);">

                    <!-- Card Header -->
                    <HBox alignment="CENTER_LEFT" spacing="12"
                          style="-fx-padding: 18 24; -fx-background-color: #FFF5F5; -fx-background-radius: 16 16 0 0; -fx-border-color: #FFEBEE; -fx-border-width: 0 0 1 0;">
                        <Label text="👤" style="-fx-font-size: 16px;"/>
                        <VBox>
                            <Label text="Informations personnelles"
                                   style="-fx-font-size: 15px; -fx-font-weight: bold; -fx-text-fill: #B71C1C; -fx-font-family: 'Georgia';"/>
                            <Label text="Modifiez vos informations ci-dessous"
                                   style="-fx-font-size: 11px; -fx-text-fill: #9E9E9E;"/>
                        </VBox>
                    </HBox>

                    <!-- Form Fields -->
                    <VBox spacing="16" style="-fx-padding: 24;">

                        <!-- Row 1: Prénom + Nom -->
                        <HBox spacing="16">
                            <VBox spacing="6" HBox.hgrow="ALWAYS">
                                <Label text="Prénom" style="-fx-font-size: 11px; -fx-font-weight: bold; -fx-text-fill: #616161;"/>
                                <TextField fx:id="tfPrenom" promptText="Votre prénom"
                                           style="-fx-background-color: #FFFAFA; -fx-background-radius: 10; -fx-border-color: #FFCDD2; -fx-border-radius: 10; -fx-padding: 10 14; -fx-font-size: 13px;"/>
                            </VBox>
                            <VBox spacing="6" HBox.hgrow="ALWAYS">
                                <Label text="Nom" style="-fx-font-size: 11px; -fx-font-weight: bold; -fx-text-fill: #616161;"/>
                                <TextField fx:id="tfNom" promptText="Votre nom"
                                           style="-fx-background-color: #FFFAFA; -fx-background-radius: 10; -fx-border-color: #FFCDD2; -fx-border-radius: 10; -fx-padding: 10 14; -fx-font-size: 13px;"/>
                            </VBox>
                        </HBox>

                        <!-- Row 2: Email + Téléphone -->
                        <HBox spacing="16">
                            <VBox spacing="6" HBox.hgrow="ALWAYS">
                                <Label text="Adresse e-mail" style="-fx-font-size: 11px; -fx-font-weight: bold; -fx-text-fill: #616161;"/>
                                <TextField fx:id="tfEmail" promptText="votre@email.com"
                                           style="-fx-background-color: #FFFAFA; -fx-background-radius: 10; -fx-border-color: #FFCDD2; -fx-border-radius: 10; -fx-padding: 10 14; -fx-font-size: 13px;"/>
                            </VBox>
                            <VBox spacing="6" HBox.hgrow="ALWAYS">
                                <Label text="Numéro de téléphone" style="-fx-font-size: 11px; -fx-font-weight: bold; -fx-text-fill: #616161;"/>
                                <TextField fx:id="tfTel" promptText="+216 XX XXX XXX"
                                           style="-fx-background-color: #FFFAFA; -fx-background-radius: 10; -fx-border-color: #FFCDD2; -fx-border-radius: 10; -fx-padding: 10 14; -fx-font-size: 13px;"/>
                            </VBox>
                        </HBox>

                        <!-- Row 3: Date de naissance + Sexe -->
                        <HBox spacing="16">
                            <VBox spacing="6" HBox.hgrow="ALWAYS">
                                <Label text="Date de naissance" style="-fx-font-size: 11px; -fx-font-weight: bold; -fx-text-fill: #616161;"/>
                                <DatePicker fx:id="dpDateNaissance"
                                            style="-fx-background-color: #FFFAFA; -fx-background-radius: 10; -fx-border-color: #FFCDD2; -fx-border-radius: 10; -fx-font-size: 13px;"
                                            maxWidth="Infinity"/>
                            </VBox>
                            <VBox spacing="6" HBox.hgrow="ALWAYS">
                                <Label text="Sexe" style="-fx-font-size: 11px; -fx-font-weight: bold; -fx-text-fill: #616161;"/>
                                <ComboBox fx:id="cbSexe" promptText="Sélectionner..."
                                          style="-fx-background-color: #FFFAFA; -fx-background-radius: 10; -fx-border-color: #FFCDD2; -fx-border-radius: 10; -fx-font-size: 13px;"
                                          maxWidth="Infinity"/>
                            </VBox>
                        </HBox>

                        <!-- Row 4: Classe -->
                        <VBox spacing="6">
                            <Label text="Classe" style="-fx-font-size: 11px; -fx-font-weight: bold; -fx-text-fill: #616161;"/>
                            <TextField fx:id="tfClasse" promptText="Classe actuelle"
                                       editable="false"
                                       style="-fx-background-color: #EEEEEE; -fx-background-radius: 10; -fx-border-color: #E0E0E0; -fx-border-radius: 10; -fx-padding: 10 14; -fx-font-size: 13px;"/>
                        </VBox>

                        <!-- Feedback label -->
                        <Label fx:id="lblFormMsg" text="" wrapText="true"
                               style="-fx-font-size: 12px; -fx-text-fill: #4CAF50;"/>

                        <!-- Actions -->
                        <HBox spacing="12" alignment="CENTER_RIGHT">
                            <Button fx:id="btnReset" text="Annuler"
                                    onAction="#handleReset"
                                    style="-fx-background-color: transparent; -fx-border-color: #FFCDD2; -fx-border-radius: 10; -fx-text-fill: #C62828; -fx-font-size: 13px; -fx-padding: 10 24; -fx-cursor: hand;"/>
                            <Button fx:id="btnSave" text="  Enregistrer les modifications  "
                                    onAction="#handleSave"
                                    style="-fx-background-color: linear-gradient(to right, #C62828, #EF5350);
               -fx-text-fill: white;
               -fx-font-size: 13px;
               -fx-font-weight: bold;
               -fx-background-radius: 10;
               -fx-padding: 10 24;
               -fx-cursor: hand;
               -fx-effect: dropshadow(gaussian, rgba(198,40,40,0.4), 8, 0, 0, 3);"/>
                        </HBox>

                    </VBox>
                </VBox>

            </VBox>
        </HBox>

        <!-- Bottom padding -->
        <Pane prefHeight="20"/>
    </VBox>
</ScrollPane>
