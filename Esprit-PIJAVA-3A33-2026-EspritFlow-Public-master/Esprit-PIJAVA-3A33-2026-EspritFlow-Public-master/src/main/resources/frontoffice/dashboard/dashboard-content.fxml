<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.chart.*?>

<HBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="piJava.Controllers.frontoffice.FrontDashboardController"
      stylesheets="@dashboard.css"
      prefWidth="1400" prefHeight="860"
      styleClass="root-bg">

    <ScrollPane fitToWidth="true" styleClass="page-scroll" HBox.hgrow="ALWAYS">

        <VBox spacing="22" styleClass="main-container">
            <!-- HEADER -->
            <HBox alignment="CENTER_LEFT" spacing="16">
                <VBox HBox.hgrow="ALWAYS" spacing="4">
                    <Label text="Tableau de bord" styleClass="title"/>
                    <Label text="ESPRIT Flow · Année académique 2024–2025" styleClass="subtitle"/>
                </VBox>
                <Button text="＋ Nouvel étudiant" styleClass="btn-primary"/>
            </HBox>

            <!-- 4 STAT CARDS
                 IMPORTANT: each card uses ONE styleClass only (e.g. "red-card").
                 Do NOT add "card" as a second class — it causes a specificity
                 conflict that overwrites the gradient with a plain gray fill.
            -->
            <HBox spacing="16">

                <VBox HBox.hgrow="ALWAYS" prefHeight="130"
                      spacing="6" alignment="TOP_LEFT"
                      styleClass="red-card">
                    <Label text="👥  Total Étudiants" styleClass="card-label"/>
                    <Label text="1 284"               styleClass="card-number"/>
                    <Label text="+24 ce mois-ci"       styleClass="card-sub"/>
                </VBox>

                <VBox HBox.hgrow="ALWAYS" prefHeight="130"
                      spacing="6" alignment="TOP_LEFT"
                      styleClass="red-card-light">
                    <Label text="📚  Classes"          styleClass="card-label"/>
                    <Label text="24"                   styleClass="card-number"/>
                    <Label text="+3 cette semaine"     styleClass="card-sub"/>
                </VBox>

                <VBox HBox.hgrow="ALWAYS" prefHeight="130"
                      spacing="6" alignment="TOP_LEFT"
                      styleClass="red-card-mid">
                    <Label text="👨‍🏫  Enseignants"      styleClass="card-label"/>
                    <Label text="86"                   styleClass="card-number"/>
                    <Label text="Permanents"           styleClass="card-sub"/>
                </VBox>

                <VBox HBox.hgrow="ALWAYS" prefHeight="130"
                      spacing="6" alignment="TOP_LEFT"
                      styleClass="red-card-soft">
                    <Label text="📖  Matières"         styleClass="card-label"/>
                    <Label text="32"                   styleClass="card-number"/>
                    <Label text="Programmes actifs"   styleClass="card-sub"/>
                </VBox>

            </HBox>

            <!-- CHART + SIDE PANEL ROW -->
            <HBox spacing="16" VBox.vgrow="ALWAYS">

                <VBox HBox.hgrow="ALWAYS" styleClass="panel">
                    <Label text="Inscriptions mensuelles" styleClass="panel-title"/>
                    <BarChart fx:id="enrollmentChart" prefHeight="260"
                              styleClass="chart" animated="true">
                        <xAxis><CategoryAxis/></xAxis>
                        <yAxis><NumberAxis/></yAxis>
                    </BarChart>
                </VBox>

                <VBox prefWidth="260" spacing="14" styleClass="panel">
                    <Label text="Répartition par filière" styleClass="panel-title"/>

                    <VBox spacing="10">
                        <HBox spacing="10" alignment="CENTER_LEFT">
                            <Label text="●" styleClass="dot-red"/>
                            <Label text="Génie Logiciel"  styleClass="filiere-label" HBox.hgrow="ALWAYS"/>
                            <Label text="34%" styleClass="filiere-pct"/>
                        </HBox>
                        <HBox spacing="10" alignment="CENTER_LEFT">
                            <Label text="●" styleClass="dot-red2"/>
                            <Label text="Data Science"    styleClass="filiere-label" HBox.hgrow="ALWAYS"/>
                            <Label text="22%" styleClass="filiere-pct"/>
                        </HBox>
                        <HBox spacing="10" alignment="CENTER_LEFT">
                            <Label text="●" styleClass="dot-red3"/>
                            <Label text="Réseaux Télécom" styleClass="filiere-label" HBox.hgrow="ALWAYS"/>
                            <Label text="18%" styleClass="filiere-pct"/>
                        </HBox>
                        <HBox spacing="10" alignment="CENTER_LEFT">
                            <Label text="●" styleClass="dot-pink"/>
                            <Label text="Business IT"     styleClass="filiere-label" HBox.hgrow="ALWAYS"/>
                            <Label text="15%" styleClass="filiere-pct"/>
                        </HBox>
                        <HBox spacing="10" alignment="CENTER_LEFT">
                            <Label text="●" styleClass="dot-gray"/>
                            <Label text="Autres"          styleClass="filiere-label" HBox.hgrow="ALWAYS"/>
                            <Label text="11%" styleClass="filiere-pct"/>
                        </HBox>
                    </VBox>

                    <Region VBox.vgrow="ALWAYS"/>

                    <VBox spacing="8" styleClass="mini-stat-box">
                        <HBox alignment="CENTER_LEFT" spacing="8">
                            <Label text="Taux de présence" styleClass="mini-stat-label" HBox.hgrow="ALWAYS"/>
                            <Label text="87%" styleClass="mini-stat-value"/>
                        </HBox>
                        <HBox alignment="CENTER_LEFT" spacing="8">
                            <Label text="Taux de réussite" styleClass="mini-stat-label" HBox.hgrow="ALWAYS"/>
                            <Label text="91%" styleClass="mini-stat-value"/>
                        </HBox>
                        <HBox alignment="CENTER_LEFT" spacing="8">
                            <Label text="Étudiants actifs" styleClass="mini-stat-label" HBox.hgrow="ALWAYS"/>
                            <Label text="1 201" styleClass="mini-stat-value"/>
                        </HBox>
                    </VBox>

                </VBox>
            </HBox>

            <!-- STUDENTS TABLE -->
            <VBox styleClass="panel">
                <HBox alignment="CENTER_LEFT" spacing="12">
                    <Label text="Étudiants récents" styleClass="panel-title" HBox.hgrow="ALWAYS"/>
                    <Button text="Voir tout →" styleClass="btn-ghost"/>
                </HBox>

                <TableView fx:id="studentsTable" prefHeight="200" styleClass="table">
                    <columns>
                        <TableColumn fx:id="nameCol" text="Nom"      prefWidth="220"/>
                        <TableColumn fx:id="gradeCol" text="Classe"   prefWidth="120"/>
                        <TableColumn fx:id="courseCol" text="Filière"  prefWidth="180"/>
                        <TableColumn fx:id="attendanceCol" text="Présence" prefWidth="120"/>
                        <TableColumn fx:id="statusCol" text="Statut"   prefWidth="120"/>
                    </columns>
                </TableView>
            </VBox>

        </VBox>
    </ScrollPane>


</HBox>
