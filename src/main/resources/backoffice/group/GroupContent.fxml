<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Priority?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<ScrollPane xmlns="http://javafx.com/javafx"
          xmlns:fx="http://javafx.com/fxml"
          fx:controller="piJava.Controllers.backoffice.group.GroupContentController"
          fitToWidth="true"
          fitToHeight="true"
          styleClass="groups-scroll"
          stylesheets="@group.css">

    <VBox spacing="16" styleClass="groups-root">
        <padding>
            <Insets top="16" right="24" bottom="16" left="24"/>
        </padding>

        <HBox alignment="CENTER_LEFT" spacing="16" styleClass="page-header">
            <VBox HBox.hgrow="ALWAYS" spacing="4">
                <HBox alignment="CENTER_LEFT" spacing="8">
                    <Label text="Backoffice" styleClass="breadcrumb-inactive"/>
                    <Label text="›" styleClass="breadcrumb-sep"/>
                    <Label text="Groupes" styleClass="breadcrumb-active"/>
                </HBox>
                <Label text="Gestion des Groupes Projet" styleClass="page-title"/>
            </VBox>
            <TextField fx:id="searchField"
                       promptText="Rechercher..."
                       styleClass="search-bar"/>
            <Button fx:id="addGroupBtn" text="+ Nouveau Groupe"
                    styleClass="btn-add" onAction="#handleAdd"/>
        </HBox>

        <HBox spacing="16" styleClass="stats-row">
            <HBox spacing="10" styleClass="stat-card">
                <VBox spacing="2">
                    <Label fx:id="totalGroupsLabel" text="0" styleClass="stat-number"/>
                    <Label text="Total Groupes" styleClass="stat-label"/>
                </VBox>
            </HBox>

            <HBox spacing="10" styleClass="stat-card">
                <VBox spacing="2">
                    <Label fx:id="activeGroupsLabel" text="0" styleClass="stat-number"/>
                    <Label text="Actifs" styleClass="stat-label"/>
                </VBox>
            </HBox>

            <HBox spacing="10" styleClass="stat-card">
                <VBox spacing="2">
                    <Label fx:id="totalMembersLabel" text="0" styleClass="stat-number"/>
                    <Label text="Membres" styleClass="stat-label"/>
                </VBox>
            </HBox>

            <HBox spacing="10" styleClass="stat-card">
                <VBox spacing="2">
                    <Label fx:id="coveredSubjectsLabel" text="0" styleClass="stat-number"/>
                    <Label text="Matières" styleClass="stat-label"/>
                </VBox>
            </HBox>
        </HBox>

        <HBox spacing="10" styleClass="filter-bar">
            <Label text="Filtrer :" styleClass="filter-label"/>
            <ComboBox fx:id="statusFilter" promptText="Statut" styleClass="filter-combo"/>
            <Button fx:id="resetFilterBtn" text="Reset"
                    styleClass="btn-reset" onAction="#handleResetFilters"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Label fx:id="resultCountLabel" text="0 résultat(s)" styleClass="result-count"/>
        </HBox>

        <VBox styleClass="table-panel" VBox.vgrow="ALWAYS">
            <TableView fx:id="groupTable" styleClass="group-table" VBox.vgrow="ALWAYS">
                <columns>
                    <TableColumn fx:id="idCol" text="ID" prefWidth="60"/>
                    <TableColumn fx:id="nameCol" text="GROUPE" prefWidth="200"/>
                    <TableColumn fx:id="projectCol" text="MATIÈRE" prefWidth="150"/>
                    <TableColumn fx:id="membersCol" text="MEMBRES" prefWidth="100"/>
                    <TableColumn fx:id="descCol" text="DESCRIPTION" prefWidth="200"/>
                    <TableColumn fx:id="statusCol" text="STATUT" prefWidth="100"/>
                    <TableColumn fx:id="actionsCol" text="ACTIONS" prefWidth="150"/>
                </columns>
                <placeholder>
                    <VBox alignment="CENTER" spacing="12">
                        <Label text="Aucun groupe trouvé" styleClass="empty-title"/>
                    </VBox>
                </placeholder>
            </TableView>

            <HBox styleClass="table-footer">
                <Label fx:id="footerLabel" text="Affichage de 0 entrées" styleClass="footer-text"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Button fx:id="prevBtn" text="‹" styleClass="page-btn" onAction="#handlePrev"/>
                <Label fx:id="pageLabel" text="1" styleClass="page-label"/>
                <Button fx:id="nextBtn" text="›" styleClass="page-btn" onAction="#handleNext"/>
            </HBox>
        </VBox>

    </VBox>
</ScrollPane>