<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.*?>

<ScrollPane xmlns="http://javafx.com/javafx"
          xmlns:fx="http://javafx.com/fxml"
          fx:controller="piJava.Controllers.backoffice.group.PropositionReunionController"
          fitToWidth="true"
          fitToHeight="true"
          styleClass="groups-scroll"
          stylesheets="@group.css">

    <VBox spacing="16" styleClass="main-content">
        
        <VBox spacing="8">
            <HBox alignment="CENTER_LEFT" spacing="8">
                <Label text="Backoffice" styleClass="breadcrumb-inactive"/>
                <Label text="›" styleClass="breadcrumb-sep"/>
                <Label text="Groupes" styleClass="breadcrumb-inactive"/>
                <Label text="›" styleClass="breadcrumb-sep"/>
                <Label fx:id="groupNameBreadcrumb" text="Propositions" styleClass="breadcrumb-active"/>
            </HBox>
            <HBox alignment="CENTER_LEFT" spacing="16">
                <Label fx:id="pageTitle" text="Propositions de Réunion" styleClass="page-title"/>
                <Region HBox.hgrow="ALWAYS"/>
                <TextField fx:id="searchField" promptText="Rechercher..." styleClass="search-bar"/>
                <Button fx:id="addPropositionBtn" text="+ Nouvelle" styleClass="btn-add" onAction="#handleAdd"/>
            </HBox>
        </VBox>

        <HBox spacing="16" styleClass="stats-row">
            <HBox spacing="10" styleClass="stat-card">
                <VBox spacing="2">
                    <Label fx:id="totalPropositionsLabel" text="0" styleClass="stat-number"/>
                    <Label text="Total" styleClass="stat-label"/>
                </VBox>
            </HBox>

            <HBox spacing="10" styleClass="stat-card">
                <VBox spacing="2">
                    <Label fx:id="acceptedPropositionsLabel" text="0" styleClass="stat-number"/>
                    <Label text="Acceptées" styleClass="stat-label"/>
                </VBox>
            </HBox>

            <HBox spacing="10" styleClass="stat-card">
                <VBox spacing="2">
                    <Label fx:id="pendingPropositionsLabel" text="0" styleClass="stat-number"/>
                    <Label text="En attente" styleClass="stat-label"/>
                </VBox>
            </HBox>
        </HBox>

        <VBox spacing="16" styleClass="cards-section">
            <Label text="Liste des Propositions" styleClass="section-title"/>
            <FlowPane fx:id="propositionsContainer" styleClass="propositions-flow" hgap="16" vgap="16"/>
        </VBox>

        <HBox alignment="CENTER_LEFT">
            <Label fx:id="footerLabel" text="Affichage de 0 propositions" styleClass="footer-text"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Button fx:id="backBtn" text="← Retour aux groupes" styleClass="btn-back" onAction="#handleBack"/>
        </HBox>

    </VBox>
</ScrollPane>