<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>

<HBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="piJava.Controllers.backoffice.taches.TacheEditController"
      styleClass="dashboard-root"
      stylesheets="@tache-edit.css">

    <VBox styleClass="main-content" spacing="20" HBox.hgrow="ALWAYS" fillWidth="true">

        <!-- HEADER -->
        <HBox alignment="CENTER_LEFT" spacing="20">
            <VBox HBox.hgrow="ALWAYS">
                <Label text="Modifier la tâche" styleClass="page-title"/>
                <Label text="Mettre à jour les informations de la tâche" styleClass="page-subtitle"/>
            </VBox>
        </HBox>

        <!-- SCROLLABLE AREA -->
        <ScrollPane fitToWidth="true" pannable="true" VBox.vgrow="ALWAYS" styleClass="scroll-pane">
            <content>

                <VBox styleClass="form-card" spacing="8">

                    <!-- ═══════════════════════════════════════════════════════ -->
                    <!-- SECTION: INFORMATIONS GÉNÉRALES -->
                    <!-- ═══════════════════════════════════════════════════════ -->
                    <Label text="📋 INFORMATIONS GÉNÉRALES" styleClass="section-header"/>

                    <HBox spacing="8" alignment="CENTER_LEFT">
                        <Label text="Titre de la tâche" styleClass="form-label-highlight"/>
                        <Label text="*" styleClass="required-star"/>
                    </HBox>
                    <TextField fx:id="txtTitre" promptText="Entrez le titre de la tâche..." styleClass="input"/>
                    <Label fx:id="lblTitreError" styleClass="error-label"/>

                    <Label text="Description détaillée" styleClass="form-label"/>
                    <TextArea fx:id="txtDescription" promptText="Décrivez la tâche en détail..." styleClass="input" wrapText="true"/>
                    <Label fx:id="lblDescriptionError" styleClass="error-label"/>

                    <!-- ═══════════════════════════════════════════════════════ -->
                    <!-- SECTION: PLANIFICATION -->
                    <!-- ═══════════════════════════════════════════════════════ -->
                    <Label text="📅 PLANIFICATION" styleClass="section-header"/>

                    <HBox spacing="15">
                        <VBox spacing="5" HBox.hgrow="ALWAYS">
                            <HBox spacing="8" alignment="CENTER_LEFT">
                                <Label text="Date &amp; Heure début" styleClass="form-label-highlight"/>
                                <Label text="*" styleClass="required-star"/>
                            </HBox>
                            <HBox spacing="10">
                                <DatePicker fx:id="dpDateDebut" styleClass="input" HBox.hgrow="ALWAYS"/>
                                <TextField fx:id="txtHeureDebut" promptText="HH:mm" styleClass="input" prefWidth="80"/>
                            </HBox>
                            <Label fx:id="lblDateDebutError" styleClass="error-label"/>
                        </VBox>

                        <VBox spacing="5" HBox.hgrow="ALWAYS">
                            <HBox spacing="8" alignment="CENTER_LEFT">
                                <Label text="Date &amp; Heure fin" styleClass="form-label-highlight"/>
                                <Label text="*" styleClass="required-star"/>
                            </HBox>
                            <HBox spacing="10">
                                <DatePicker fx:id="dpDateFin" styleClass="input" HBox.hgrow="ALWAYS"/>
                                <TextField fx:id="txtHeureFin" promptText="HH:mm" styleClass="input" prefWidth="80"/>
                            </HBox>
                            <Label fx:id="lblDateFinError" styleClass="error-label"/>
                        </VBox>
                    </HBox>

                    <HBox spacing="8" alignment="CENTER_LEFT">
                        <Label text="Durée estimée" styleClass="form-label"/>
                        <Label text="(minutes)" styleClass="info-badge"/>
                    </HBox>
                    <TextField fx:id="txtDuree" promptText="Ex: 120" styleClass="input"/>
                    <Label fx:id="lblDureeError" styleClass="error-label"/>

                    <!-- ═══════════════════════════════════════════════════════ -->
                    <!-- SECTION: CLASSIFICATION -->
                    <!-- ═══════════════════════════════════════════════════════ -->
                    <Label text="🏷️ CLASSIFICATION" styleClass="section-header"/>

                    <HBox spacing="15">
                        <VBox spacing="5" HBox.hgrow="ALWAYS">
                            <HBox spacing="8" alignment="CENTER_LEFT">
                                <Label text="Type" styleClass="form-label-highlight"/>
                                <Label text="*" styleClass="required-star"/>
                            </HBox>
                            <ComboBox fx:id="cbType" promptText="Sélectionner..." styleClass="input" HBox.hgrow="ALWAYS"/>
                            <Label fx:id="lblTypeError" styleClass="error-label"/>
                        </VBox>

                        <VBox spacing="5" HBox.hgrow="ALWAYS">
                            <HBox spacing="8" alignment="CENTER_LEFT">
                                <Label text="Priorité" styleClass="form-label-highlight"/>
                                <Label text="*" styleClass="required-star"/>
                            </HBox>
                            <ComboBox fx:id="cbPriorite" promptText="Sélectionner..." styleClass="input" HBox.hgrow="ALWAYS"/>
                            <Label fx:id="lblPrioriteError" styleClass="error-label"/>
                        </VBox>

                        <VBox spacing="5" HBox.hgrow="ALWAYS">
                            <HBox spacing="8" alignment="CENTER_LEFT">
                                <Label text="Statut" styleClass="form-label-highlight"/>
                                <Label text="*" styleClass="required-star"/>
                            </HBox>
                            <ComboBox fx:id="cbStatut" promptText="Sélectionner..." styleClass="input" HBox.hgrow="ALWAYS"/>
                            <Label fx:id="lblStatutError" styleClass="error-label"/>
                        </VBox>
                    </HBox>

                    <!-- ═══════════════════════════════════════════════════════ -->
                    <!-- SECTION: ASSIGNATION -->
                    <!-- ═══════════════════════════════════════════════════════ -->
                    <Label text="👤 ASSIGNATION" styleClass="section-header"/>

                    <HBox spacing="8" alignment="CENTER_LEFT">
                        <Label text="Utilisateur assigné" styleClass="form-label-highlight"/>
                        <Label text="*" styleClass="required-star"/>
                    </HBox>
                    <ComboBox fx:id="cbUser" promptText="Sélectionner un utilisateur..." styleClass="input"/>
                    <Label fx:id="lblUserError" styleClass="error-label"/>

                    <!-- ═══════════════════════════════════════════════════════ -->
                    <!-- ACTIONS -->
                    <!-- ═══════════════════════════════════════════════════════ -->
                    <Region minHeight="20"/>
                    <HBox spacing="15" alignment="CENTER_RIGHT" styleClass="form-section">
                        <Button text="❌ Annuler" onAction="#handleCancel" styleClass="btn-secondary"/>
                        <Button text="💾 Mettre à jour" onAction="#handleUpdate" styleClass="btn-primary"/>
                    </HBox>

                </VBox>

            </content>
        </ScrollPane>
    </VBox>
</HBox>