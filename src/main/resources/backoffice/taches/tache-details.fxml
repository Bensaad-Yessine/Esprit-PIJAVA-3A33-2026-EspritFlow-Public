<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="piJava.Controllers.backoffice.taches.TachesDetailsController"
      styleClass="dashboard-root"
      spacing="0"
      stylesheets="@tache-details.css">

    <!-- HEADER SECTION -->
    <VBox styleClass="header-section" spacing="6">
        <Label text="Task Details" styleClass="page-title"/>
        <Label text="Full information about this task" styleClass="page-subtitle"/>
    </VBox>

    <!-- MAIN CONTENT WITH SCROLLPANE -->
    <ScrollPane styleClass="scroll-pane" fitToWidth="true" VBox.vgrow="ALWAYS">

        <!-- WRAP BOTH PANELS IN ONE HBOX -->
        <HBox spacing="28" styleClass="main-content">

            <!-- LEFT PANEL - Task Information -->
            <VBox spacing="18" styleClass="task-card" prefWidth="460" minWidth="400">

                <!-- Title Section -->
                <VBox spacing="10">
                    <Label text="Task Title" styleClass="section-title"/>
                    <Label fx:id="lblTitle" styleClass="task-title" wrapText="true"/>
                </VBox>

                <Separator/>

                <!-- Description Section -->
                <VBox spacing="10">
                    <Label text="Description" styleClass="section-title"/>
                    <Label fx:id="lblDescription" wrapText="true" styleClass="task-desc"
                           maxHeight="120" minHeight="60"/>
                </VBox>

                <Separator/>

                <!-- Status & Priority Row -->
                <HBox spacing="20" alignment="CENTER_LEFT">
                    <VBox spacing="6" HBox.hgrow="ALWAYS">
                        <Label text="Current Status" styleClass="info-label"/>
                        <Label fx:id="lblStatus" styleClass="badge-status"/>
                    </VBox>
                    <VBox spacing="6" HBox.hgrow="ALWAYS">
                        <Label text="Priority Level" styleClass="info-label"/>
                        <Label fx:id="lblPriority" styleClass="badge-priority"/>
                    </VBox>
                </HBox>

                <Separator/>

                <!-- Task Type & Assignment -->
                <VBox spacing="12">
                    <HBox styleClass="info-row" spacing="12" alignment="CENTER_LEFT">
                        <Label text="Task Type:" styleClass="info-label"/>
                        <Label fx:id="lblType" styleClass="info-value"/>
                    </HBox>

                    <HBox styleClass="info-row" spacing="12" alignment="CENTER_LEFT">
                        <Label text="Assigned To:" styleClass="info-label"/>
                        <Label fx:id="lblUserId" styleClass="task-user"/>
                    </HBox>
                </VBox>

                <!-- Metadata Footer -->
                <HBox spacing="15" style="-fx-padding: 12 0 0 0; -fx-border-color: linear-gradient(from 0% 0% to 100% 0%, transparent, #3B4A5A, transparent); -fx-border-width: 1 0 0 0;">
                    <Label text="Created: " styleClass="info-label"/>
                    <Label fx:id="lblCreatedAt" text="--" styleClass="info-value"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Label text="ID: " styleClass="info-label"/>
                    <Label fx:id="lblTaskId" text="#0000" styleClass="info-value" style="-fx-text-fill: #64748B;"/>
                </HBox>

            </VBox>

            <!-- RIGHT PANEL - Timeline & AI -->
            <VBox spacing="20" styleClass="task-card" HBox.hgrow="ALWAYS">

                <!-- Timeline Section -->
                <VBox spacing="14">
                    <Label text="Timeline et Scheduling" styleClass="section-title"/>

                    <GridPane vgap="12" hgap="20">
                        <columnConstraints>
                            <ColumnConstraints minWidth="140" prefWidth="140"/>
                            <ColumnConstraints hgrow="ALWAYS"/>
                        </columnConstraints>

                        <Label text="Start Date:" styleClass="info-label" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                        <Label fx:id="lblDateDebut" styleClass="info-value" GridPane.rowIndex="0" GridPane.columnIndex="1"/>

                        <Label text="End Date:" styleClass="info-label" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
                        <Label fx:id="lblDateFin" styleClass="info-value" GridPane.rowIndex="1" GridPane.columnIndex="1"/>

                        <Label text="Deadline:" styleClass="info-label" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
                        <Label fx:id="lblDateEcheance" styleClass="info-value" GridPane.rowIndex="2" GridPane.columnIndex="1"/>

                        <Label text="Est. Duration:" styleClass="info-label" GridPane.rowIndex="3" GridPane.columnIndex="0"/>
                        <Label fx:id="lblDureeEstimee" styleClass="info-value" GridPane.rowIndex="3" GridPane.columnIndex="1"/>
                    </GridPane>
                </VBox>

                <Separator/>

                <!-- AI Prediction Section -->
                <VBox spacing="12" styleClass="ai-section">
                    <HBox spacing="10" alignment="CENTER_LEFT">
                        <Label text="🤖 AI Prediction" style="-fx-text-fill: #60A5FA; -fx-font-weight: bold; -fx-font-size: 15px;"/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <Label fx:id="lblPrediction" styleClass="label-prediction"/>
                    </HBox>

                    <VBox spacing="6">
                        <ProgressBar fx:id="progressPrediction" prefWidth="400" maxWidth="Infinity" progress="0.75"/>
                        <HBox spacing="10" alignment="CENTER_LEFT">
                            <Label text="Confidence:" styleClass="info-label" style="-fx-font-size: 11px;"/>
                            <Label fx:id="lblConfidence" text="85%" style="-fx-text-fill: #60A5FA; -fx-font-weight: bold; -fx-font-size: 11px;"/>
                            <Region HBox.hgrow="ALWAYS"/>
                            <Label text="Last updated: Just now" style="-fx-text-fill: #64748B; -fx-font-size: 10px;"/>
                        </HBox>
                    </VBox>
                </VBox>

                <Separator/>

                <!-- History Section -->
                <VBox spacing="10" VBox.vgrow="ALWAYS">
                    <HBox spacing="10" alignment="CENTER_LEFT">
                        <Label text="Activity History" styleClass="section-title" style="-fx-border-width: 0;"/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <Button text="🔄 Refresh" styleClass="btn-primary" style="-fx-padding: 6 12; -fx-font-size: 11px;"/>
                    </HBox>

                    <ListView fx:id="lvHistory" VBox.vgrow="ALWAYS" style="-fx-pref-height: 220;"/>
                </VBox>

            </VBox>

        </HBox>

    </ScrollPane>

    <!-- ACTION BUTTONS BAR -->
    <HBox styleClass="button-container" alignment="CENTER_LEFT">

        <!-- Primary Actions -->
        <HBox spacing="10" alignment="CENTER_LEFT">
            <Button fx:id="btnStart" text="▶ Start Task" onAction="#handleStartAction" styleClass="btn-primary"/>
            <Button fx:id="btnPause" text="⏸ Pause" onAction="#handlePauseAction" styleClass="btn-edit"/>
            <Button fx:id="btnFinish" text="✔ Complete" onAction="#handleFinishAction" styleClass="btn-details"/>
            <Button fx:id="btnAbandon" text="✖ Abandon" onAction="#handleAbandonAction" styleClass="btn-delete"/>
            <Button fx:id="btnNoActions" text="No actions available" disable="true" styleClass="btn-disabled" visible="false"/>
        </HBox>

        <Region HBox.hgrow="ALWAYS"/>

        <!-- Secondary Actions -->
        <HBox spacing="10" alignment="CENTER_RIGHT">
            <Button fx:id="btnBack" text="⬅ Back to List" onAction="#handleBack" styleClass="btn-primary" style="-fx-padding: 12 20;"/>
        </HBox>

    </HBox>

</VBox>