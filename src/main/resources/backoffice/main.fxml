<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>

<HBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="piJava.Controllers.backoffice.MainController"
      prefWidth="1400" prefHeight="800"
      stylesheets="@sidebar.css">

    <!--
        fx:id="sidebar"  →  JavaFX auto-injects "sidebarController" in MainController
        source path starts from resources/ root, matches your sidebar.fxml location
    -->
    <fx:include fx:id="sidebar" source="sidebar.fxml"/>

    <!-- Content area: pages are swapped into here by SidebarController -->
    <StackPane fx:id="contentArea" HBox.hgrow="ALWAYS"/>

</HBox>
