<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefHeight="760.0" prefWidth="1250.0"
            xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="piJava.Controllers.backoffice.objectifsante.AfficherObjectifsController"
            stylesheets="@style.css"
            style="-fx-background-color: #0b1220;">

    <top>
        <HBox styleClass="top-bar" spacing="12">
            <padding>
                <Insets top="16" right="24" bottom="16" left="24"/>
            </padding>
            <children>
                <VBox spacing="2">
                    <children>
                        <Label text="Esprit Flow" styleClass="top-bar-title"/>
                        <Label text="Health Goals &amp; Well-being Manager" styleClass="top-bar-subtitle"/>
                    </children>
                </VBox>
            </children>
        </HBox>
    </top>

    <center>
        <ScrollPane fitToWidth="true" pannable="true"
                    style="-fx-background: transparent; -fx-background-color: transparent;">
            <content>
                <VBox spacing="20" style="-fx-padding: 24;">
                    <children>

                        <HBox spacing="20" styleClass="hero-card">
                            <children>
                                <VBox spacing="8" HBox.hgrow="ALWAYS">
                                    <children>
                                        <Label text="💙 Gérez vos objectifs santé" styleClass="hero-title"/>
                                        <Label text="Créez, modifiez et suivez les objectifs bien-être avec une interface moderne, claire et professionnelle."
                                               wrapText="true"
                                               styleClass="hero-subtitle"/>
                                    </children>
                                </VBox>
                                <Label text="🎯" styleClass="hero-sticker"/>
                            </children>
                        </HBox>

                        <HBox alignment="CENTER_LEFT" spacing="12">
                            <children>
                                <Label text="Objectifs santé" styleClass="label-title"/>
                                <Region HBox.hgrow="ALWAYS"/>
                                <Button text="Voir suivis" styleClass="secondary-button" onAction="#ouvrirAfficherSuivis"/>
                                <Button text="Ajouter objectif" styleClass="primary-button" onAction="#ouvrirAjouterObjectif"/>
                                <Button text="Modifier objectif" styleClass="secondary-button" onAction="#ouvrirModifierObjectif"/>
                                <Button text="Supprimer objectif" styleClass="danger-button" onAction="#supprimerObjectif"/>
                            </children>
                        </HBox>

                        <HBox spacing="16">
                            <children>
                                <VBox spacing="6" styleClass="stat-card" HBox.hgrow="ALWAYS">
                                    <children>
                                        <Label text="📌 Objectifs" styleClass="stat-title"/>
                                        <Label text="Suivi global" styleClass="stat-value"/>
                                    </children>
                                </VBox>

                                <VBox spacing="6" styleClass="stat-card" HBox.hgrow="ALWAYS">
                                    <children>
                                        <Label text="⚡ Priorité" styleClass="stat-title"/>
                                        <Label text="Gestion rapide" styleClass="stat-value"/>
                                    </children>
                                </VBox>

                                <VBox spacing="6" styleClass="stat-card" HBox.hgrow="ALWAYS">
                                    <children>
                                        <Label text="📅 Période" styleClass="stat-title"/>
                                        <Label text="Début / fin" styleClass="stat-value"/>
                                    </children>
                                </VBox>
                            </children>
                        </HBox>

                        <VBox styleClass="card" spacing="14" VBox.vgrow="ALWAYS">
                            <children>
                                <HBox alignment="CENTER_LEFT">
                                    <children>
                                        <Label text="📋 Liste des objectifs" styleClass="label-title"/>
                                        <Region HBox.hgrow="ALWAYS"/>
                                        <Label text="Actifs" styleClass="badge-blue"/>
                                    </children>
                                </HBox>

                                <TableView fx:id="tableObjectifs" VBox.vgrow="ALWAYS">
                                    <columns>
                                        <TableColumn fx:id="colId" prefWidth="90.0" text="#"/>
                                        <TableColumn fx:id="colUserId" prefWidth="110.0" text="ID Utilisateur"/>
                                        <TableColumn fx:id="colUserNom" prefWidth="150.0" text="Nom"/>
                                        <TableColumn fx:id="colUserPrenom" prefWidth="150.0" text="Prénom"/>
                                        <TableColumn fx:id="colTitre" prefWidth="220.0" text="Objectif"/>
                                        <TableColumn fx:id="colType" prefWidth="140.0" text="Catégorie"/>
                                        <TableColumn fx:id="colValeurCible" prefWidth="120.0" text="Cible"/>
                                        <TableColumn fx:id="colDateDebut" prefWidth="130.0" text="Début"/>
                                        <TableColumn fx:id="colDateFin" prefWidth="130.0" text="Fin"/>
                                        <TableColumn fx:id="colPriorite" prefWidth="120.0" text="Priorité"/>
                                        <TableColumn fx:id="colStatut" prefWidth="130.0" text="Statut"/>
                                    </columns>
                                </TableView>
                            </children>
                        </VBox>

                    </children>
                </VBox>
            </content>
        </ScrollPane>
    </center>
</BorderPane>