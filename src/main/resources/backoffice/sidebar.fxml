<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.shape.*?>
<?import javafx.scene.image.*?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="piJava.Controllers.backoffice.SidebarController"
      styleClass="sidebar"
      minWidth="270" prefWidth="270" maxWidth="270"
      spacing="0"
      stylesheets="@sidebar.css">

    <!-- ═══ LOGO ═══ -->
    <HBox styleClass="logo-container" alignment="CENTER_LEFT" spacing="10">
        <StackPane styleClass="logo-mark">
            <Label text="EF" styleClass="logo-mark-text"/>
        </StackPane>
        <VBox spacing="1">
            <Label text="ESPRIT FLOW" styleClass="logo-title"/>
            <Label text="Back Office Administrateur" styleClass="logo-subtitle"/>
        </VBox>
    </HBox>

    <!-- ═══ PROFILE / SESSION ═══ -->
    <VBox styleClass="profile-section" spacing="8">

        <!-- Avatar + name + badge row -->
        <HBox alignment="CENTER_LEFT" spacing="12">
            <StackPane fx:id="avatarStack" minWidth="48" minHeight="48"
                       maxWidth="48" maxHeight="48">
                <Circle fx:id="avatarCircle" radius="24" styleClass="avatar-circle"
                        centerX="24" centerY="24"/>
                <ImageView fx:id="avatarImage" fitWidth="48" fitHeight="48"
                           preserveRatio="true" visible="false"/>
                <Label fx:id="avatarInitials" text="?" styleClass="avatar-initials"/>
                <Circle radius="6" styleClass="online-dot"
                        centerX="42" centerY="42"/>
            </StackPane>

            <VBox spacing="4">
                <Label fx:id="profileName" text="Chargement..." styleClass="profile-name"/>
                <HBox styleClass="role-badge" alignment="CENTER_LEFT" spacing="5">
                    <Circle radius="3" styleClass="badge-dot"/>
                    <Label fx:id="roleBadgeLabel" text="UTILISATEUR" styleClass="badge-text"/>
                </HBox>
            </VBox>
        </HBox>

        <!-- Row 1: Prénom | Nom -->
        <HBox spacing="6">
            <VBox styleClass="info-cell" HBox.hgrow="ALWAYS">
                <Label text="Prénom" styleClass="info-label"/>
                <Label fx:id="profilePrenom" text="—" styleClass="info-value"/>
            </VBox>
            <VBox styleClass="info-cell" HBox.hgrow="ALWAYS">
                <Label text="Nom" styleClass="info-label"/>
                <Label fx:id="profileNom" text="—" styleClass="info-value"/>
            </VBox>
        </HBox>

        <!-- Row 2: Email (full width) -->
        <VBox styleClass="info-cell">
            <Label text="Email" styleClass="info-label"/>
            <Label fx:id="profileEmail" text="—" styleClass="info-value"/>
        </VBox>

        <!-- Row 3: Rôle | Session -->
        <HBox spacing="6">
            <VBox styleClass="info-cell" HBox.hgrow="ALWAYS">
                <Label text="Rôle" styleClass="info-label"/>
                <Label fx:id="profileRole" text="—" styleClass="info-value"/>
            </VBox>
            <VBox styleClass="info-cell" HBox.hgrow="ALWAYS">
                <Label text="Session" styleClass="info-label"/>
                <HBox alignment="CENTER_LEFT" spacing="5">
                    <Circle radius="4" styleClass="session-live-dot"/>
                    <Label fx:id="sessionStatus" text="En ligne" styleClass="info-value-green"/>
                </HBox>
            </VBox>
        </HBox>

    </VBox>

    <!-- ═══ NAVIGATION ═══ -->
    <ScrollPane styleClass="nav-scroll" fitToWidth="true" VBox.vgrow="ALWAYS"
                hbarPolicy="NEVER" vbarPolicy="AS_NEEDED">
        <VBox styleClass="nav-container" spacing="1">

            <Label text="MENU PRINCIPAL" styleClass="nav-section-title"/>

            <HBox fx:id="dashboardBtn" styleClass="nav-item" alignment="CENTER_LEFT"
                  spacing="9" onMouseClicked="#goToDashboard">
                <StackPane styleClass="nav-icon-wrap">
                    <Label styleClass="nav-icon-label" text="&#8962;"/>
                </StackPane>
                <Label text="Tableau de bord" styleClass="nav-item-label" HBox.hgrow="ALWAYS"/>
            </HBox>

            <HBox fx:id="utilisateursBtn" styleClass="nav-item" alignment="CENTER_LEFT"
                  spacing="9" onMouseClicked="#goToUsers">
                <StackPane styleClass="nav-icon-wrap">
                    <Label styleClass="nav-icon-label" text="&#128100;"/>
                </StackPane>
                <Label text="Utilisateurs" styleClass="nav-item-label" HBox.hgrow="ALWAYS"/>
            </HBox>

            <HBox fx:id="tachesBtn" styleClass="nav-item" alignment="CENTER_LEFT"
                  spacing="9" onMouseClicked="#goToTaches">
                <StackPane styleClass="nav-icon-wrap">
                    <Label styleClass="nav-icon-label" text="&#10003;"/>
                </StackPane>
                <Label text="Tâches" styleClass="nav-item-label" HBox.hgrow="ALWAYS"/>
                <Label fx:id="tachesBadge" text="14" styleClass="nav-badge"/>
            </HBox>

            <HBox fx:id="classesBtn" styleClass="nav-item" alignment="CENTER_LEFT"
                  spacing="9" onMouseClicked="#goToClasses">
                <StackPane styleClass="nav-icon-wrap">
                    <Label styleClass="nav-icon-label" text="&#9638;"/>
                </StackPane>
                <Label text="Classes" styleClass="nav-item-label" HBox.hgrow="ALWAYS"/>
            </HBox>

            <HBox fx:id="matieresBtn" styleClass="nav-item" alignment="CENTER_LEFT"
                  spacing="9" onMouseClicked="#goToMatieres">
                <StackPane styleClass="nav-icon-wrap">
                    <Label styleClass="nav-icon-label" text="&#128218;"/>
                </StackPane>
                <Label text="Matières" styleClass="nav-item-label" HBox.hgrow="ALWAYS"/>
            </HBox>

            <HBox fx:id="enseignantsBtn" styleClass="nav-item" alignment="CENTER_LEFT"
                  spacing="9" onMouseClicked="#goToEnseignants">
                <StackPane styleClass="nav-icon-wrap">
                    <Label styleClass="nav-icon-label" text="&#127891;"/>
                </StackPane>
                <Label text="Enseignants" styleClass="nav-item-label" HBox.hgrow="ALWAYS"/>
            </HBox>

            <Label text="GESTION ACADÉMIQUE" styleClass="nav-section-title"/>

            <HBox fx:id="sallesBtn" styleClass="nav-item" alignment="CENTER_LEFT"
                  spacing="9" onMouseClicked="#goToSalles">
                <StackPane styleClass="nav-icon-wrap">
                    <Label styleClass="nav-icon-label" text="&#127970;"/>
                </StackPane>
                <Label text="Salles" styleClass="nav-item-label" HBox.hgrow="ALWAYS"/>
            </HBox>

            <HBox fx:id="seancesBtn" styleClass="nav-item" alignment="CENTER_LEFT"
                  spacing="9" onMouseClicked="#goToSeances">
                <StackPane styleClass="nav-icon-wrap">
                    <Label styleClass="nav-icon-label" text="&#128197;"/>
                </StackPane>
                <Label text="Séances" styleClass="nav-item-label" HBox.hgrow="ALWAYS"/>
            </HBox>

            <HBox fx:id="objectfiSanteBtn" styleClass="nav-item" alignment="CENTER_LEFT"
                  spacing="9" onMouseClicked="#goToObjectifsSante">
                <StackPane styleClass="nav-icon-wrap">
                    <Label styleClass="nav-icon-label" text="&#128221;"/>
                </StackPane>
                <Label text="Notes" styleClass="nav-item-label" HBox.hgrow="ALWAYS"/>
            </HBox>

            <Label text="COMMUNICATION" styleClass="nav-section-title"/>

            <HBox fx:id="notificationsBtn" styleClass="nav-item" alignment="CENTER_LEFT"
                  spacing="9" onMouseClicked="#goToNotifications">
                <StackPane styleClass="nav-icon-wrap">
                    <Label styleClass="nav-icon-label" text="&#128276;"/>
                </StackPane>
                <Label text="Notifications" styleClass="nav-item-label" HBox.hgrow="ALWAYS"/>
                <Label fx:id="notifBadge" text="3" styleClass="nav-badge nav-badge-red"/>
            </HBox>

        </VBox>
    </ScrollPane>

    <!-- ═══ LOGOUT ═══ -->
    <VBox styleClass="logout-section">
        <HBox fx:id="logoutBtn" styleClass="logout-item" alignment="CENTER_LEFT"
              spacing="9" onMouseClicked="#logout">
            <StackPane styleClass="nav-icon-wrap logout-icon-wrap">
                <Label styleClass="nav-icon-label logout-icon-label" text="&#9211;"/>
            </StackPane>
            <Label text="Déconnexion" styleClass="logout-label"/>
        </HBox>
    </VBox>

</VBox>
