<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Priority?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.control.ScrollPane?>
<BorderPane prefHeight="760.0" prefWidth="640.0"
            xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="piJava.Controllers.backoffice.suivibienetre.ModifierSuiviController"
            stylesheets="@style.css"
            style="-fx-background-color: #0d0f14;">

    <top>
        <HBox styleClass="top-bar" spacing="12">
            <padding>
                <Insets top="16" right="24" bottom="16" left="24"/>
            </padding>
            <children>
                <VBox spacing="2">
                    <children>
                        <Label text="Esprit Flow" styleClass="top-bar-title"/>
                        <Label text="Update a well-being follow-up" styleClass="top-bar-subtitle"/>
                    </children>
                </VBox>
                <Region HBox.hgrow="ALWAYS"/>
            </children>
        </HBox>
    </top>

    <center>
        <ScrollPane fitToWidth="true" pannable="true"
                    style="-fx-background: transparent; -fx-background-color: transparent;">
        <content>
        <VBox spacing="20" style="-fx-padding: 24;">
            <children>

                <!-- HERO SECTION -->
                <HBox spacing="20" styleClass="hero-card">
                    <children>
                        <VBox spacing="8" HBox.hgrow="ALWAYS">
                            <children>
                                <Label text="💙 Modifier un suivi bien-être" styleClass="hero-title"/>
                                <Label text="Mettez à jour les données du suivi pour garder un historique clair, précis et professionnel."
                                       wrapText="true"
                                       styleClass="hero-subtitle"/>
                            </children>
                        </VBox>
                        <Label text="✏️" styleClass="hero-sticker"/>
                    </children>
                </HBox>

                <!-- FORM CARD -->
                <VBox styleClass="card" spacing="18" VBox.vgrow="ALWAYS">
                    <children>
                        <HBox alignment="CENTER_LEFT">
                            <children>
                                <Label text="🛠️ Modification du suivi" styleClass="label-title"/>
                                <Region HBox.hgrow="ALWAYS"/>
                                <Label text="Édition" styleClass="badge-yellow"/>
                            </children>
                        </HBox>

                        <GridPane hgap="18" vgap="18">
                            <padding>
                                <Insets top="10" right="10" bottom="10" left="10"/>
                            </padding>

                            <Label text="Date saisie :" styleClass="form-label" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                            <VBox spacing="4" GridPane.rowIndex="0" GridPane.columnIndex="1">
                                <children>
                                    <DatePicker fx:id="dpDateSaisie" prefWidth="300.0"/>
                                    <Label fx:id="errDateSaisie" styleClass="error-label"/>
                                </children>
                            </VBox>

                            <Label text="Humeur :" styleClass="form-label" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
                            <VBox spacing="4" GridPane.rowIndex="1" GridPane.columnIndex="1">
                                <children>
                                    <ComboBox fx:id="cbHumeur" prefWidth="300.0"/>
                                    <Label fx:id="errHumeur" styleClass="error-label"/>
                                </children>
                            </VBox>

                            <Label text="Qualité sommeil :" styleClass="form-label" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
                            <VBox spacing="4" GridPane.rowIndex="2" GridPane.columnIndex="1">
                                <children>
                                    <TextField fx:id="txtQualiteSommeil" promptText="Valeur de 0 à 10"/>
                                    <Label fx:id="errQualiteSommeil" styleClass="error-label"/>
                                </children>
                            </VBox>

                            <Label text="Niveau énergie :" styleClass="form-label" GridPane.rowIndex="3" GridPane.columnIndex="0"/>
                            <VBox spacing="4" GridPane.rowIndex="3" GridPane.columnIndex="1">
                                <children>
                                    <TextField fx:id="txtNiveauEnergie" promptText="Valeur de 0 à 10"/>
                                    <Label fx:id="errNiveauEnergie" styleClass="error-label"/>
                                </children>
                            </VBox>

                            <Label text="Niveau stress :" styleClass="form-label" GridPane.rowIndex="4" GridPane.columnIndex="0"/>
                            <VBox spacing="4" GridPane.rowIndex="4" GridPane.columnIndex="1">
                                <children>
                                    <TextField fx:id="txtNiveauStress" promptText="Valeur de 0 à 10"/>
                                    <Label fx:id="errNiveauStress" styleClass="error-label"/>
                                </children>
                            </VBox>

                            <Label text="Qualité alimentation :" styleClass="form-label" GridPane.rowIndex="5" GridPane.columnIndex="0"/>
                            <VBox spacing="4" GridPane.rowIndex="5" GridPane.columnIndex="1">
                                <children>
                                    <TextField fx:id="txtQualiteAlimentation" promptText="Valeur de 0 à 10"/>
                                    <Label fx:id="errQualiteAlimentation" styleClass="error-label"/>
                                </children>
                            </VBox>

                            <Label text="Notes libres :" styleClass="form-label" GridPane.rowIndex="6" GridPane.columnIndex="0"/>
                            <VBox spacing="4" GridPane.rowIndex="6" GridPane.columnIndex="1">
                                <children>
                                    <TextField fx:id="txtNotesLibres" promptText="Modifier la note"/>
                                    <Label fx:id="errNotesLibres" styleClass="error-label"/>
                                </children>
                            </VBox>
                        </GridPane>

                        <HBox spacing="12" alignment="CENTER_RIGHT">
                            <children>
                                <Region HBox.hgrow="ALWAYS"/>
                                <Button text="Retour"
                                        styleClass="secondary-button"
                                        onAction="#retourSuivis"/>

                                <Button text="Modifier"
                                        styleClass="primary-button"
                                        onAction="#modifierSuivi"/>
                            </children>
                        </HBox>
                    </children>
                </VBox>

            </children>
        </VBox>
        </content>
        </ScrollPane>
    </center>

</BorderPane>