<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Priority?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.ComboBox?>
<BorderPane prefHeight="760.0" prefWidth="1250.0"
            xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="piJava.Controllers.backoffice.suivibienetre.AfficherSuivisController"
            stylesheets="@style.css"
            style="-fx-background-color: #0d0f14;">

    <top>
        <HBox styleClass="top-bar" spacing="12">
            <padding>
                <Insets top="16" right="24" bottom="16" left="24"/>
            </padding>
            <children>
                <VBox spacing="2">
                    <children>
                        <Label text="Esprit Flow" styleClass="top-bar-title"/>
                        <Label text="Well-being Follow-ups" styleClass="top-bar-subtitle"/>
                    </children>
                </VBox>

                <Region HBox.hgrow="ALWAYS"/>

                <Button text="Objectifs" styleClass="nav-button" onAction="#ouvrirObjectifs"/>
                <Button text="Suivis" styleClass="nav-button" onAction="#actualiserSuivis"/>
            </children>
        </HBox>
    </top>

    <center>
        <ScrollPane fitToWidth="true" pannable="true"
                    style="-fx-background: transparent; -fx-background-color: transparent;">
            <content>
        <VBox spacing="20" style="-fx-padding: 24;">
            <children>

                <!-- HERO SECTION -->
                <HBox spacing="20" styleClass="hero-card">
                    <children>
                        <VBox spacing="8" HBox.hgrow="ALWAYS">
                            <children>
                                <Label text="💙 Analyse des suivis bien-être" styleClass="hero-title"/>
                                <Label text="Visualisez l’humeur, le sommeil, l’énergie, le stress et l’alimentation dans une interface claire et moderne."
                                       wrapText="true"
                                       styleClass="hero-subtitle"/>
                            </children>
                        </VBox>
                        <Label text="📈" styleClass="hero-sticker"/>
                    </children>
                </HBox>

                <!-- TITLE + ACTIONS -->
                <HBox alignment="CENTER_LEFT" spacing="12">
                    <children>
                        <Label text="Suivis bien-être" styleClass="label-title"/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <Button text="Ajouter suivi" styleClass="primary-button" onAction="#ouvrirAjouterSuivi"/>
                        <Button text="Modifier suivi" styleClass="secondary-button" onAction="#ouvrirModifierSuivi"/>
                        <Button text="Supprimer suivi" styleClass="danger-button" onAction="#supprimerSuivi"/>
                    </children>
                </HBox>

                <!-- SMALL DASHBOARD CARDS -->
                <HBox spacing="16">
                    <children>
                        <VBox spacing="6" styleClass="stat-card" HBox.hgrow="ALWAYS">
                            <children>
                                <Label text="😊 Humeur" styleClass="stat-title"/>
                                <Label text="État global" styleClass="stat-value"/>
                            </children>
                        </VBox>

                        <VBox spacing="6" styleClass="stat-card" HBox.hgrow="ALWAYS">
                            <children>
                                <Label text="⚡ Énergie" styleClass="stat-title"/>
                                <Label text="Suivi quotidien" styleClass="stat-value"/>
                            </children>
                        </VBox>

                        <VBox spacing="6" styleClass="stat-card" HBox.hgrow="ALWAYS">
                            <children>
                                <Label text="📊 Score" styleClass="stat-title"/>
                                <Label text="Performance santé" styleClass="stat-value"/>
                            </children>
                        </VBox>
                    </children>
                </HBox>
                <HBox alignment="CENTER_LEFT" spacing="12">
                    <children>
                        <ComboBox fx:id="cbTri" prefWidth="180.0"/>

                        <Button text="Réinitialiser"
                                styleClass="secondary-button"
                                onAction="#reinitialiserTri"/>
                    </children>
                </HBox>

                <!-- TABLE CARD -->
                <VBox styleClass="card" spacing="14" VBox.vgrow="ALWAYS">
                    <children>
                        <HBox alignment="CENTER_LEFT">
                            <children>
                                <Label text="🩺 Liste des suivis" styleClass="label-title"/>
                                <Region HBox.hgrow="ALWAYS"/>
                                <Label text="Historique" styleClass="badge-blue"/>
                            </children>
                        </HBox>

                        <TableView fx:id="tableSuivis" VBox.vgrow="ALWAYS">
                            <columns>

                                <TableColumn fx:id="colDateSaisie" prefWidth="120.0" text="Date saisie"/>
                                <TableColumn fx:id="colHumeur" prefWidth="130.0" text="Humeur"/>
                                <TableColumn fx:id="colQualiteSommeil" prefWidth="120.0" text="Sommeil"/>
                                <TableColumn fx:id="colNiveauEnergie" prefWidth="120.0" text="Énergie"/>
                                <TableColumn fx:id="colNiveauStress" prefWidth="120.0" text="Stress"/>
                                <TableColumn fx:id="colQualiteAlimentation" prefWidth="145.0" text="Alimentation"/>
                                <TableColumn fx:id="colScore" prefWidth="110.0" text="Score"/>
                                <TableColumn fx:id="colActions" prefWidth="200.0" text="Actions"/>

                            </columns>
                        </TableView>
                    </children>
                </VBox>

            </children>
        </VBox>
    </content>
</ScrollPane>
        </center>

</BorderPane>