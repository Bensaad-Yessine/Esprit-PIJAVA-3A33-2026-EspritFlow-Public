<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.shape.*?>
<?import javafx.scene.chart.*?>

<HBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="piJava.Controllers.backoffice.DashboardController"
      styleClass="dashboard-root"
      prefWidth="1400" prefHeight="800"
      stylesheets="@dashboard.css">

    <VBox styleClass="main-content" spacing="20" HBox.hgrow="ALWAYS">

        <!-- Header -->
        <HBox alignment="CENTER_LEFT" spacing="20" styleClass="header">
            <VBox HBox.hgrow="ALWAYS">
                <Label text="Tableau de bord" styleClass="page-title"/>
                <Label text="Bienvenue sur ESPRIT Flow" styleClass="page-subtitle"/>
            </VBox>
            <TextField promptText="Rechercher..." styleClass="search-field"/>
            <Button fx:id="newStudentBtn" text="+ Nouvel étudiant" styleClass="btn-primary"/>
        </HBox>

        <!-- Stat Cards -->
        <HBox spacing="16" styleClass="stats-row">
            <VBox styleClass="stat-card" fx:id="totalStudentsCard">
                <Label text="👥 Total Étudiants" styleClass="stat-label"/>
                <Label fx:id="totalStudentsLbl" text="0" styleClass="stat-number"/>
                <Label text="+24 ce mois-ci" styleClass="stat-trend"/>
            </VBox>

            <VBox styleClass="stat-card">
                <Label text="📚 Classes actives" styleClass="stat-label"/>
                <Label fx:id="activeClassesLbl" text="0" styleClass="stat-number"/>
                <Label text="+3 cette semaine" styleClass="stat-trend"/>
            </VBox>

            <VBox styleClass="stat-card">
                <Label text="👨‍🏫 Enseignants" styleClass="stat-label"/>
                <Label fx:id="teachersLbl" text="0" styleClass="stat-number"/>
                <Label text="Permanents" styleClass="stat-sub"/>
            </VBox>

            <VBox styleClass="stat-card">
                <Label text="🚫 Utilisateurs Bannis" styleClass="stat-label"/>
                <Label fx:id="bannedUsersLbl" text="0" styleClass="stat-number"/>
                <Label text="Programmes" styleClass="stat-sub"/>
            </VBox>
        </HBox>

        <!-- Charts & Performance -->
        <HBox spacing="16" VBox.vgrow="ALWAYS" styleClass="charts-row">
            <!-- Enrollment Chart -->
            <VBox styleClass="chart-panel" HBox.hgrow="ALWAYS">
                <Label text="Inscriptions mensuelles" styleClass="panel-title"/>
                <Label text="Évolution des inscriptions 2024" styleClass="panel-subtitle"/>
                <BarChart fx:id="enrollmentChart" styleClass="bar-chart" VBox.vgrow="ALWAYS">
                    <xAxis>
                        <CategoryAxis side="BOTTOM" styleClass="axis-label"/>
                    </xAxis>
                    <yAxis>
                        <NumberAxis side="LEFT" styleClass="axis-label"/>
                    </yAxis>
                </BarChart>
            </VBox>

            <!-- Performance by Class -->
            <VBox styleClass="performance-panel" prefWidth="380">
                <Label text="Performance par classe" styleClass="panel-title"/>
                <Label text="Moyennes générales" styleClass="panel-subtitle"/>
                <VBox spacing="12" styleClass="performance-list">
                    <VBox spacing="4">
                        <HBox alignment="CENTER_LEFT" spacing="10">
                            <Label text="3ème GL" styleClass="class-name"/>
                            <Label text="14.2/20" styleClass="class-score"/>
                        </HBox>
                        <ProgressBar progress="0.71" styleClass="progress-bar"/>
                    </VBox>
                    <VBox spacing="4">
                        <HBox alignment="CENTER_LEFT" spacing="10">
                            <Label text="2ème INFO" styleClass="class-name"/>
                            <Label text="13.5/20" styleClass="class-score"/>
                        </HBox>
                        <ProgressBar progress="0.675" styleClass="progress-bar"/>
                    </VBox>
                    <VBox spacing="4">
                        <HBox alignment="CENTER_LEFT" spacing="10">
                            <Label text="1ère DS" styleClass="class-name"/>
                            <Label text="15.8/20" styleClass="class-score"/>
                        </HBox>
                        <ProgressBar progress="0.79" styleClass="progress-bar"/>
                    </VBox>
                    <VBox spacing="4">
                        <HBox alignment="CENTER_LEFT" spacing="10">
                            <Label text="2ème MT" styleClass="class-name"/>
                            <Label text="12.7/20" styleClass="class-score"/>
                        </HBox>
                        <ProgressBar progress="0.635" styleClass="progress-bar"/>
                    </VBox>
                </VBox>
            </VBox>
        </HBox>

        <!-- Students Table -->
        <VBox styleClass="table-panel">
            <HBox alignment="CENTER_LEFT">
                <Label text="Étudiants récents" styleClass="panel-title" HBox.hgrow="ALWAYS"/>
                <Button fx:id="viewAllBtn" text="Voir tout →" styleClass="link-btn"/>
            </HBox>
            <TableView fx:id="studentsTable" styleClass="custom-table">
                <columns>
                    <TableColumn fx:id="nameCol" text="ID # Nom Complet" prefWidth="250"/>
                    <TableColumn fx:id="gradeCol" text="Rôle" prefWidth="120"/>
                    <TableColumn fx:id="courseCol" text="Email" prefWidth="150"/>
                    <TableColumn fx:id="attendanceCol" text="Téléphone" prefWidth="120"/>
                    <TableColumn fx:id="statusCol" text="Statut" prefWidth="100"/>
                </columns>
            </TableView>
        </VBox>

    </VBox>
</HBox>