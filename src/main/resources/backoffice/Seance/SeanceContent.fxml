<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.*?>
<?import javafx.scene.shape.*?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="piJava.Controllers.backoffice.Seance.SeanceContentController"
      styleClass="main-content"
      spacing="24"
      stylesheets="@seance.css">

    <!-- Header -->
    <HBox alignment="CENTER_LEFT" spacing="16" styleClass="page-header">
        <VBox HBox.hgrow="ALWAYS" spacing="4">
            <HBox alignment="CENTER_LEFT" spacing="8">
                <Label text="Backoffice" styleClass="breadcrumb-inactive"/>
                <Label text="›" styleClass="breadcrumb-sep"/>
                <Label text="Gestion des Séances" styleClass="breadcrumb-active"/>
            </HBox>
            <Label text="Gestion des Séances" styleClass="page-title"/>
        </VBox>
    </HBox>

    <!-- Top Stats Panel (Cards) -->
    <HBox alignment="CENTER_LEFT" spacing="20">
        <!-- Title left -->
        <HBox alignment="CENTER_LEFT" spacing="10" prefWidth="250">
            <Label text="🗓️" styleClass="icon-text" style="-fx-background-color: #312e81; -fx-padding: 8; -fx-background-radius: 5;"/>
            <Label text="Séances ESPRIT" style="-fx-text-fill: white; -fx-font-size: 20px; -fx-font-weight: bold;"/>
        </HBox>

        <!-- Stats -->
        <HBox spacing="15" HBox.hgrow="ALWAYS">
            <!-- Total -->
            <VBox styleClass="stat-card" prefWidth="180" spacing="15">
                <HBox alignment="CENTER_LEFT" spacing="10">
                    <Label fx:id="lblTotalCount" text="0" styleClass="stat-number"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Label text="🗓️" styleClass="icon-text" style="-fx-background-color: #8b5cf6; -fx-padding: 10; -fx-background-radius: 8;"/>
                </HBox>
                <Label text="TOTAL SÉANCES" styleClass="stat-label"/>
            </VBox>

            <!-- Cours -->
            <VBox styleClass="stat-card" prefWidth="180" spacing="15">
                <HBox alignment="CENTER_LEFT" spacing="10">
                    <Label fx:id="lblCoursCount" text="0" styleClass="stat-number"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Label text="📖" styleClass="icon-text" style="-fx-background-color: #ec4899; -fx-padding: 10; -fx-background-radius: 8;"/>
                </HBox>
                <Label text="SÉANCES COURS" styleClass="stat-label"/>
            </VBox>

            <!-- Presentiel -->
            <VBox styleClass="stat-card" prefWidth="180" spacing="15">
                <HBox alignment="CENTER_LEFT" spacing="10">
                    <Label fx:id="lblPresentielCount" text="0" styleClass="stat-number"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Label text="👥" styleClass="icon-text" style="-fx-background-color: #06b6d4; -fx-padding: 10; -fx-background-radius: 8;"/>
                </HBox>
                <Label text="PRÉSENTIEL" styleClass="stat-label"/>
            </VBox>

            <!-- Cette Semaine -->
            <VBox styleClass="stat-card" prefWidth="180" spacing="15">
                <HBox alignment="CENTER_LEFT" spacing="10">
                    <Label fx:id="lblSemaineCount" text="0" styleClass="stat-number"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Label text="📅" styleClass="icon-text" style="-fx-background-color: #10b981; -fx-padding: 10; -fx-background-radius: 8;"/>
                </HBox>
                <Label text="CETTE SEMAINE" styleClass="stat-label"/>
            </VBox>
        </HBox>
    </HBox>

    <!-- Table Panel -->
    <VBox styleClass="table-panel" VBox.vgrow="ALWAYS" spacing="15">
        
        <!-- Header -->
        <HBox alignment="CENTER_LEFT">
            <Label text="🗓️ Liste Des Séances" styleClass="panel-title"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Button text="+ Nouvelle Séance" styleClass="add-btn" onAction="#handleAdd"/>
        </HBox>

        <!-- Filter Area -->
        <VBox styleClass="filter-container" spacing="10">
            <Label text="🔍 Filtrer Et Rechercher" styleClass="filter-title"/>
            <HBox spacing="15" alignment="CENTER_LEFT">
                <VBox spacing="5" HBox.hgrow="ALWAYS">
                    <Label text="Recherche" styleClass="filter-label"/>
                    <TextField fx:id="searchField" promptText="Matière, Salle..." styleClass="search-field"/>
                </VBox>
                <VBox spacing="5" HBox.hgrow="ALWAYS">
                    <Label text="Jour" styleClass="filter-label"/>
                    <ComboBox fx:id="comboJour" promptText="Tous les jours" styleClass="combo-box" maxWidth="Infinity"/>
                </VBox>
                <VBox spacing="5" HBox.hgrow="ALWAYS">
                    <Label text="Type" styleClass="filter-label"/>
                    <ComboBox fx:id="comboType" promptText="Tous les types" styleClass="combo-box" maxWidth="Infinity"/>
                </VBox>
                <VBox spacing="5" HBox.hgrow="ALWAYS">
                    <Label text="Mode" styleClass="filter-label"/>
                    <ComboBox fx:id="comboMode" promptText="Tous les modes" styleClass="combo-box" maxWidth="Infinity"/>
                </VBox>
                <VBox spacing="5" HBox.hgrow="ALWAYS">
                    <Label text="Trier par" styleClass="filter-label"/>
                    <ComboBox fx:id="comboTri" promptText="ID (Croissant)" styleClass="combo-box" maxWidth="Infinity"/>
                </VBox>
                <VBox spacing="5" alignment="BOTTOM_CENTER">
                    <Button text="↻ Réinitialiser" onAction="#handleResetFilters" style="-fx-background-color: transparent; -fx-text-fill: #3b82f6; -fx-font-weight: bold; -fx-cursor: hand;"/>
                </VBox>
            </HBox>
        </VBox>

        <!-- Table View -->
        <TableView fx:id="seanceTable" styleClass="table-view" VBox.vgrow="ALWAYS">
            <columns>
                <TableColumn fx:id="colId" text="ID" prefWidth="50"/>
                <TableColumn fx:id="colMatiere" text="Matière" prefWidth="150"/>
                <TableColumn fx:id="colClasse" text="Classe" prefWidth="100"/>
                <TableColumn fx:id="colSalle" text="Salle" prefWidth="80"/>
                <TableColumn fx:id="colJour" text="Jour" prefWidth="100"/>
                <TableColumn fx:id="colHoraires" text="Horaires" prefWidth="120"/>
                <TableColumn fx:id="colMode" text="Mode" prefWidth="120"/>
                <TableColumn fx:id="colActions" text="Actions" prefWidth="250" style="-fx-alignment: center;"/>
            </columns>
            <placeholder>
                <Label text="Aucune séance trouvée." style="-fx-text-fill: #9ca3af; -fx-font-size: 14px;"/>
            </placeholder>
        </TableView>

    </VBox>

</VBox>
