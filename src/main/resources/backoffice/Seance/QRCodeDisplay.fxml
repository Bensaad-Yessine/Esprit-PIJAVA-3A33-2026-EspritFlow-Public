<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.*?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.shape.Rectangle?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="piJava.Controllers.backoffice.Seance.QRCodeDisplayController"
      alignment="CENTER"
      spacing="20"
      style="-fx-background-color: #f3f4f6; -fx-padding: 30;">

    <Button fx:id="btnRetour" text="← Retour à la séance" onAction="#handleRetour"
            style="-fx-background-color: white; -fx-text-fill: #374151; -fx-border-color: #d1d5db; -fx-border-radius: 20; -fx-background-radius: 20; -fx-padding: 8 20; -fx-cursor: hand; -fx-font-weight: bold;"/>

    <VBox style="-fx-background-color: white; -fx-background-radius: 15; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 10, 0, 0, 5);"
          maxWidth="600" alignment="TOP_CENTER">
        
        <!-- Header -->
        <HBox style="-fx-background-color: linear-gradient(to right, #8b5cf6, #3b82f6); -fx-background-radius: 15 15 0 0; -fx-padding: 20;"
              alignment="CENTER_LEFT">
            <VBox spacing="5">
                <Label text="🔳 QR Code Présence" style="-fx-text-fill: white; -fx-font-size: 20px; -fx-font-weight: bold;"/>
                <Label text="Affichez ou imprimez ce code – il est permanent pour cette séance" style="-fx-text-fill: #e0e7ff; -fx-font-size: 13px;"/>
            </VBox>
        </HBox>

        <!-- Body -->
        <VBox spacing="25" style="-fx-padding: 30;">
            
            <!-- Details Grid -->
            <GridPane hgap="15" vgap="15">
                <!-- Row 1 -->
                <VBox style="-fx-background-color: #f8fafc; -fx-padding: 10 15; -fx-background-radius: 8; -fx-border-color: #e2e8f0; -fx-border-radius: 8;"
                      GridPane.columnIndex="0" GridPane.rowIndex="0" GridPane.hgrow="ALWAYS">
                    <Label text="MATIÈRE" style="-fx-text-fill: #64748b; -fx-font-size: 11px; -fx-font-weight: bold;"/>
                    <Label fx:id="lblMatiere" text="..." style="-fx-text-fill: #1e293b; -fx-font-size: 14px; -fx-font-weight: bold;"/>
                </VBox>
                
                <VBox style="-fx-background-color: #f8fafc; -fx-padding: 10 15; -fx-background-radius: 8; -fx-border-color: #e2e8f0; -fx-border-radius: 8;"
                      GridPane.columnIndex="1" GridPane.rowIndex="0" GridPane.hgrow="ALWAYS">
                    <Label text="CLASSE" style="-fx-text-fill: #64748b; -fx-font-size: 11px; -fx-font-weight: bold;"/>
                    <Label fx:id="lblClasse" text="..." style="-fx-text-fill: #1e293b; -fx-font-size: 14px; -fx-font-weight: bold;"/>
                </VBox>
                
                <VBox style="-fx-background-color: #f8fafc; -fx-padding: 10 15; -fx-background-radius: 8; -fx-border-color: #e2e8f0; -fx-border-radius: 8;"
                      GridPane.columnIndex="2" GridPane.rowIndex="0" GridPane.hgrow="ALWAYS">
                    <Label text="SALLE" style="-fx-text-fill: #64748b; -fx-font-size: 11px; -fx-font-weight: bold;"/>
                    <Label fx:id="lblSalle" text="..." style="-fx-text-fill: #1e293b; -fx-font-size: 14px; -fx-font-weight: bold;"/>
                </VBox>

                <!-- Row 2 -->
                <VBox style="-fx-background-color: #f8fafc; -fx-padding: 10 15; -fx-background-radius: 8; -fx-border-color: #e2e8f0; -fx-border-radius: 8;"
                      GridPane.columnIndex="0" GridPane.rowIndex="1" GridPane.hgrow="ALWAYS">
                    <Label text="DATE" style="-fx-text-fill: #64748b; -fx-font-size: 11px; -fx-font-weight: bold;"/>
                    <Label fx:id="lblDate" text="..." style="-fx-text-fill: #1e293b; -fx-font-size: 14px; -fx-font-weight: bold;"/>
                </VBox>
                
                <VBox style="-fx-background-color: #f8fafc; -fx-padding: 10 15; -fx-background-radius: 8; -fx-border-color: #e2e8f0; -fx-border-radius: 8;"
                      GridPane.columnIndex="1" GridPane.rowIndex="1" GridPane.hgrow="ALWAYS">
                    <Label text="DÉBUT" style="-fx-text-fill: #64748b; -fx-font-size: 11px; -fx-font-weight: bold;"/>
                    <Label fx:id="lblDebut" text="..." style="-fx-text-fill: #1e293b; -fx-font-size: 14px; -fx-font-weight: bold;"/>
                </VBox>
                
                <VBox style="-fx-background-color: #f8fafc; -fx-padding: 10 15; -fx-background-radius: 8; -fx-border-color: #e2e8f0; -fx-border-radius: 8;"
                      GridPane.columnIndex="2" GridPane.rowIndex="1" GridPane.hgrow="ALWAYS">
                    <Label text="FIN" style="-fx-text-fill: #64748b; -fx-font-size: 11px; -fx-font-weight: bold;"/>
                    <Label fx:id="lblFin" text="..." style="-fx-text-fill: #1e293b; -fx-font-size: 14px; -fx-font-weight: bold;"/>
                </VBox>
            </GridPane>

            <!-- QR Code Section -->
            <HBox alignment="CENTER" spacing="20">
                <HBox alignment="CENTER" style="-fx-background-color: #ecfdf5; -fx-padding: 5 15; -fx-background-radius: 20;">
                    <Label text="● QR actif - Scan illimité" style="-fx-text-fill: #10b981; -fx-font-weight: bold; -fx-font-size: 12px;"/>
                </HBox>
                
                <VBox alignment="CENTER" style="-fx-background-color: white; -fx-padding: 15; -fx-background-radius: 10; -fx-border-color: #e2e8f0; -fx-border-radius: 10; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.05), 5, 0, 0, 2);">
                    <ImageView fx:id="qrImageView" fitWidth="250" fitHeight="250" preserveRatio="true" />
                </VBox>
            </HBox>

            <!-- Action Buttons -->
            <HBox alignment="CENTER" spacing="20" style="-fx-padding: 10 0 0 0;">
                <Button fx:id="btnImprimer" text="🖨 Imprimer / Poster" onAction="#handleImprimer"
                        style="-fx-background-color: #6366f1; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 10 25; -fx-background-radius: 20; -fx-cursor: hand;"/>
                <Button fx:id="btnVoirPresences" text="👀 Voir les présences" onAction="#handleVoirPresences"
                        style="-fx-background-color: white; -fx-text-fill: #6366f1; -fx-font-weight: bold; -fx-padding: 10 25; -fx-background-radius: 20; -fx-border-color: #6366f1; -fx-border-radius: 20; -fx-cursor: hand;"/>
            </HBox>

        </VBox>
    </VBox>
</VBox>
