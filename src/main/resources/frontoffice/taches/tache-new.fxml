<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.collections.FXCollections?>
<?import java.lang.String?>
<?import javafx.geometry.Insets?>

<HBox xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="piJava.Controllers.frontoffice.taches.TacheNewController"
      styleClass="root-bg"
      stylesheets="@tache-new.css"
      prefWidth="1200" prefHeight="850">

    <ScrollPane fitToWidth="true" styleClass="page-scroll" HBox.hgrow="ALWAYS">
        <VBox styleClass="main-container">

            <!-- HEADER SECTION -->
            <VBox spacing="8" styleClass="header-section">
                <Label text="Nouvelle tâche" styleClass="title"/>
                <Label text="Créer et configurer une nouvelle tâche dans le système" styleClass="subtitle"/>
            </VBox>

            <!-- FORM CARD -->
            <VBox styleClass="form-card">

                <!-- TWO COLUMN GRID -->
                <GridPane styleClass="form-grid" vgap="20" hgap="100">

                    <!-- COLUMN 1 -->
                    <!-- TITRE -->
                    <VBox spacing="6" GridPane.columnIndex="0" GridPane.rowIndex="0">
                        <Label text="Titre *" styleClass="field-label">
                            <graphic>
                                <Region styleClass="field-icon icon-title"/>
                            </graphic>
                        </Label>
                        <TextField fx:id="txtTitre" styleClass="form-field" promptText="Entrez le titre de la tâche"/>
                        <Label fx:id="lblTitreError" styleClass="error-label"/>
                    </VBox>

                    <!-- TYPE -->
                    <VBox spacing="6" GridPane.columnIndex="1" GridPane.rowIndex="0">
                        <Label text="Type *" styleClass="field-label">
                            <graphic>
                                <Region styleClass="field-icon icon-type"/>
                            </graphic>
                        </Label>
                        <ComboBox fx:id="cbType" styleClass="form-field combo-box">
                            <items>
                                <FXCollections fx:factory="observableArrayList">
                                    <String fx:value="MANUEL"/>
                                    <String fx:value="REVISION"/>
                                    <String fx:value="REUNION"/>
                                    <String fx:value="EMPLOI"/>
                                    <String fx:value="SANTE"/>
                                </FXCollections>
                            </items>
                        </ComboBox>
                        <Label fx:id="lblTypeError" styleClass="error-label"/>
                    </VBox>

                    <!-- DATE DEBUT -->
                    <VBox spacing="6" GridPane.columnIndex="0" GridPane.rowIndex="1">
                        <Label text="Date début *" styleClass="field-label">
                            <graphic>
                                <Region styleClass="field-icon icon-calendar"/>
                            </graphic>
                        </Label>
                        <DatePicker fx:id="dpDateDebut" styleClass="date-picker" promptText="Sélectionnez une date"/>
                        <Label fx:id="lblDateDebutError" styleClass="error-label"/>
                    </VBox>

                    <!-- HEURE DEBUT -->
                    <VBox spacing="6" GridPane.columnIndex="1" GridPane.rowIndex="1">
                        <Label text="Heure début" styleClass="field-label">
                            <graphic>
                                <Region styleClass="field-icon icon-clock"/>
                            </graphic>
                        </Label>
                        <TextField fx:id="txtHeureDebut" styleClass="form-field" promptText="HH:MM"/>
                    </VBox>

                    <!-- DATE FIN -->
                    <VBox spacing="6" GridPane.columnIndex="0" GridPane.rowIndex="2">
                        <Label text="Date fin *" styleClass="field-label">
                            <graphic>
                                <Region styleClass="field-icon icon-calendar"/>
                            </graphic>
                        </Label>
                        <DatePicker fx:id="dpDateFin" styleClass="date-picker" promptText="Sélectionnez une date"/>
                        <Label fx:id="lblDateFinError" styleClass="error-label"/>
                    </VBox>

                    <!-- HEURE FIN -->
                    <VBox spacing="6" GridPane.columnIndex="1" GridPane.rowIndex="2">
                        <Label text="Heure fin" styleClass="field-label">
                            <graphic>
                                <Region styleClass="field-icon icon-clock"/>
                            </graphic>
                        </Label>
                        <TextField fx:id="txtHeureFin" styleClass="form-field" promptText="HH:MM"/>
                    </VBox>

                    <!-- PRIORITE -->
                    <VBox spacing="6" GridPane.columnIndex="0" GridPane.rowIndex="3">
                        <Label text="Priorité *" styleClass="field-label">
                            <graphic>
                                <Region styleClass="field-icon icon-priority"/>
                            </graphic>
                        </Label>
                        <ComboBox fx:id="cbPriorite" styleClass="form-field combo-box">
                            <items>
                                <FXCollections fx:factory="observableArrayList">
                                    <String fx:value="ELEVEE"/>
                                    <String fx:value="MOYEN"/>
                                    <String fx:value="FAIBLE"/>
                                </FXCollections>
                            </items>
                        </ComboBox>
                        <Label fx:id="lblPrioriteError" styleClass="error-label"/>
                    </VBox>

                    <!-- STATUT -->
                    <VBox spacing="6" GridPane.columnIndex="1" GridPane.rowIndex="3">
                        <Label text="Statut" styleClass="field-label">
                            <graphic>
                                <Region styleClass="field-icon icon-status"/>
                            </graphic>
                        </Label>
                        <ComboBox fx:id="cbStatut" styleClass="form-field combo-box">
                            <items>
                                <FXCollections fx:factory="observableArrayList">
                                    <String fx:value="EN_COURS"/>
                                    <String fx:value="A_FAIRE"/>
                                    <String fx:value="PAUSED"/>
                                    <String fx:value="TERMINEE"/>
                                </FXCollections>
                            </items>
                        </ComboBox>
                        <Label fx:id="lblStatutError" styleClass="error-label"/>
                    </VBox>

                    <!-- DUREE -->
                    <VBox spacing="6" GridPane.columnIndex="0" GridPane.rowIndex="4">
                        <Label text="Durée estimée" styleClass="field-label">
                            <graphic>
                                <Region styleClass="field-icon icon-duration"/>
                            </graphic>
                        </Label>
                        <TextField fx:id="txtDuree" styleClass="form-field" promptText="Minutes"/>
                        <Label fx:id="lblDureeError" styleClass="error-label"/>
                    </VBox>

                    <!-- NOTIFICATION -->
                    <VBox spacing="6" GridPane.columnIndex="1" GridPane.rowIndex="4" GridPane.valignment="CENTER">
                        <Label fx:id="lblNotification" styleClass="notification-label" text="✓ Prêt à créer la tâche"/>
                    </VBox>

                    <!-- DESCRIPTION - SPANS BOTH COLUMNS -->
                    <VBox spacing="6" GridPane.columnIndex="0" GridPane.rowIndex="5" GridPane.columnSpan="2">
                        <Label text="Description" styleClass="field-label">
                            <graphic>
                                <Region styleClass="field-icon icon-description"/>
                            </graphic>
                        </Label>
                        <TextArea fx:id="txtDescription"
                                  styleClass="form-textarea"
                                  prefRowCount="4"
                                  promptText="Décrivez les détails de la tâche..."/>
                        <Label fx:id="lblDescriptionError" styleClass="error-label"/>
                    </VBox>

                </GridPane>

                <!-- DIVIDER -->
                <Region styleClass="divider"/>

                <!-- BUTTONS -->
                <HBox spacing="16" alignment="CENTER_RIGHT" styleClass="action-buttons">
                    <Button text="Annuler" onAction="#handleBack" styleClass="btn-secondary"/>
                    <Button text="Ajouter la tâche" onAction="#handleAdd" styleClass="btn-primary"/>
                </HBox>

            </VBox>
        </VBox>
    </ScrollPane>
</HBox>