<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<AnchorPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="piJava.Controllers.frontoffice.taches.BehaviorAnalysisController"
            stylesheets="@weekly-analysis.css"
            prefHeight="750.0" prefWidth="980.0"
            styleClass="root-pane">

    <children>

        <VBox spacing="0" prefWidth="980" prefHeight="750" styleClass="main-container">

            <!-- ============================================
                 HEADER - Premium Gradient with Icons
                 ============================================ -->
            <HBox styleClass="header-section" alignment="CENTER_LEFT" spacing="18">

                <padding>
                    <Insets top="28" right="36" bottom="28" left="36"/>
                </padding>

                <StackPane style="-fx-background-color: rgba(255,255,255,0.2); -fx-background-radius: 16;
                                   -fx-min-width: 56; -fx-min-height: 56; -fx-max-width: 56; -fx-max-height: 56;
                                   -fx-border-color: rgba(255,255,255,0.3); -fx-border-radius: 16; -fx-border-width: 1;">
                    <Label text="📊" style="-fx-font-size: 28px;"/>
                </StackPane>

                <VBox spacing="5" alignment="CENTER_LEFT">
                    <Label text="Analyse Hebdomadaire de Performance"
                           styleClass="main-title"/>
                    <HBox spacing="8" alignment="CENTER_LEFT">
                        <Label text="⚡ Insights intelligents sur votre productivité"
                               styleClass="subtitle"/>
                        <Label text="● EN DIRECT"
                               style="-fx-font-size: 11px; -fx-text-fill: #00f2fe; -fx-font-weight: bold;
                                      -fx-background-color: rgba(0,242,254,0.15); -fx-background-radius: 12;
                                      -fx-padding: 3 10;"/>
                    </HBox>
                </VBox>

                <Region HBox.hgrow="ALWAYS"/>

                <Label fx:id="loadingLabel"
                       text="⏳ Chargement..."
                       styleClass="loading-indicator"/>
            </HBox>

            <!-- ============================================
                 CONTENT AREA
                 ============================================ -->
            <ScrollPane fitToWidth="true"
                        styleClass="content-scroll"
                        VBox.vgrow="ALWAYS">

                <VBox spacing="24" styleClass="content-container">

                    <padding>
                        <Insets top="24" right="36" bottom="24" left="36"/>
                    </padding>

                    <!-- ============================================
                         STATS SECTION TITLE
                         ============================================ -->
                    <HBox spacing="12" alignment="CENTER_LEFT">
                        <StackPane style="-fx-background-color: linear-gradient(to right, #4facfe, #00f2fe);
                                           -fx-background-radius: 10; -fx-min-width: 36; -fx-min-height: 36;">
                            <Label text="📈" style="-fx-font-size: 18px;"/>
                        </StackPane>
                        <Label text="Vue d'ensemble"
                               styleClass="section-title"/>
                    </HBox>

                    <!-- ============================================
                         STATS GRID - 2x2 Layout
                         ============================================ -->
                    <HBox spacing="20" alignment="CENTER">

                        <!-- LEFT COLUMN -->
                        <VBox spacing="20" HBox.hgrow="ALWAYS">

                            <!-- Completion Rate -->
                            <VBox styleClass="stat-card">
                                <padding>
                                    <Insets top="22" right="22" bottom="22" left="22"/>
                                </padding>

                                <HBox spacing="10" alignment="CENTER_LEFT">
                                    <StackPane style="-fx-background-color: linear-gradient(from 0% 100% to 100% 0%, #10b981, #34d399);
                                                       -fx-background-radius: 12; -fx-min-width: 36; -fx-min-height: 36;">
                                        <Label text="🔥" style="-fx-font-size: 18px;"/>
                                    </StackPane>
                                    <Label text="Taux de Complétion" styleClass="stat-label"/>
                                </HBox>

                                <HBox spacing="10" alignment="BASELINE_LEFT" style="-fx-padding: 12 0 8 0;">
                                    <Label fx:id="completionRateValue"
                                           text="0%"
                                           styleClass="stat-value"/>
                                    <Label fx:id="completionRateTrend"
                                           text="↑ 12%"
                                           styleClass="stat-trend positive"/>
                                </HBox>

                                <ProgressBar fx:id="completionRateBar"
                                             progress="0"
                                             maxWidth="Infinity"
                                             styleClass="progress-bar-completion"/>

                                <Label fx:id="completionRateDesc"
                                       text="Tâches terminées avec succès cette semaine"
                                       styleClass="stat-description"/>
                            </VBox>

                            <!-- Start Delay -->
                            <VBox styleClass="stat-card">
                                <padding>
                                    <Insets top="22" right="22" bottom="22" left="22"/>
                                </padding>

                                <HBox spacing="10" alignment="CENTER_LEFT">
                                    <StackPane style="-fx-background-color: linear-gradient(from 0% 100% to 100% 0%, #f59e0b, #fbbf24);
                                                       -fx-background-radius: 12; -fx-min-width: 36; -fx-min-height: 36;">
                                        <Label text="⏱️" style="-fx-font-size: 18px;"/>
                                    </StackPane>
                                    <Label text="Délai de Démarrage" styleClass="stat-label"/>
                                </HBox>

                                <HBox spacing="10" alignment="BASELINE_LEFT" style="-fx-padding: 12 0 8 0;">
                                    <Label fx:id="startDelayValue"
                                           text="0 min"
                                           styleClass="stat-value"/>
                                    <Label fx:id="startDelayTrend"
                                           text="↓ 5 min"
                                           styleClass="stat-trend positive"/>
                                </HBox>

                                <ProgressBar fx:id="startDelayBar"
                                             progress="0"
                                             maxWidth="Infinity"
                                             styleClass="progress-bar-delay"/>

                                <Label fx:id="startDelayDesc"
                                       text="Temps moyen avant de commencer une tâche"
                                       styleClass="stat-description"/>
                            </VBox>

                        </VBox>

                        <!-- RIGHT COLUMN -->
                        <VBox spacing="20" HBox.hgrow="ALWAYS">

                            <!-- Abandonment Rate -->
                            <VBox styleClass="stat-card">
                                <padding>
                                    <Insets top="22" right="22" bottom="22" left="22"/>
                                </padding>

                                <HBox spacing="10" alignment="CENTER_LEFT">
                                    <StackPane style="-fx-background-color: linear-gradient(from 0% 100% to 100% 0%, #ef4444, #f87171);
                                                       -fx-background-radius: 12; -fx-min-width: 36; -fx-min-height: 36;">
                                        <Label text="⚠️" style="-fx-font-size: 18px;"/>
                                    </StackPane>
                                    <Label text="Taux d'Abandon" styleClass="stat-label"/>
                                </HBox>

                                <HBox spacing="10" alignment="BASELINE_LEFT" style="-fx-padding: 12 0 8 0;">
                                    <Label fx:id="abandonmentRateValue"
                                           text="0%"
                                           styleClass="stat-value"/>
                                    <Label fx:id="abandonmentRateTrend"
                                           text="↓ 3%"
                                           styleClass="stat-trend negative"/>
                                </HBox>

                                <ProgressBar fx:id="abandonmentRateBar"
                                             progress="0"
                                             maxWidth="Infinity"
                                             styleClass="progress-bar-abandon"/>

                                <Label fx:id="abandonmentRateDesc"
                                       text="Tâches non terminées ou abandonnées"
                                       styleClass="stat-description"/>
                            </VBox>

                            <!-- Pause Frequency -->
                            <VBox styleClass="stat-card">
                                <padding>
                                    <Insets top="22" right="22" bottom="22" left="22"/>
                                </padding>

                                <HBox spacing="10" alignment="CENTER_LEFT">
                                    <StackPane style="-fx-background-color: linear-gradient(from 0% 100% to 100% 0%, #3b82f6, #60a5fa);
                                                       -fx-background-radius: 12; -fx-min-width: 36; -fx-min-height: 36;">
                                        <Label text="⏸️" style="-fx-font-size: 18px;"/>
                                    </StackPane>
                                    <Label text="Fréquence de Pause" styleClass="stat-label"/>
                                </HBox>

                                <HBox spacing="10" alignment="BASELINE_LEFT" style="-fx-padding: 12 0 8 0;">
                                    <Label fx:id="pauseFrequencyValue"
                                           text="0"
                                           styleClass="stat-value"/>
                                    <Label fx:id="pauseFrequencyTrend"
                                           text="→ Stable"
                                           styleClass="stat-trend neutral"/>
                                </HBox>

                                <ProgressBar fx:id="pauseFrequencyBar"
                                             progress="0"
                                             maxWidth="Infinity"
                                             styleClass="progress-bar-pause"/>

                                <Label fx:id="pauseFrequencyDesc"
                                       text="Nombre moyen de pauses par tâche"
                                       styleClass="stat-description"/>
                            </VBox>

                        </VBox>
                    </HBox>

                    <!-- ============================================
                         INSIGHTS SECTION
                         ============================================ -->
                    <HBox spacing="12" alignment="CENTER_LEFT">
                        <StackPane style="-fx-background-color: linear-gradient(to right, #a78bfa, #8b5cf6);
                                           -fx-background-radius: 10; -fx-min-width: 36; -fx-min-height: 36;">
                            <Label text="🧠" style="-fx-font-size: 18px;"/>
                        </StackPane>
                        <Label text="Insights de Productivité"
                               styleClass="section-title"/>
                    </HBox>

                    <HBox spacing="20">

                        <!-- Productive Hour -->
                        <VBox styleClass="insight-card" HBox.hgrow="ALWAYS">
                            <padding>
                                <Insets top="24" right="24" bottom="24" left="24"/>
                            </padding>

                            <HBox spacing="12" alignment="CENTER_LEFT">
                                <Label text="🕐" styleClass="insight-icon"/>
                                <Label text="Heure la Plus Productive"
                                       styleClass="insight-label"/>
                            </HBox>

                            <Label fx:id="productiveHourValue"
                                   text="--:--"
                                   styleClass="insight-value"/>

                            <Label text="Planifiez vos tâches importantes à cette heure"
                                   styleClass="insight-hint"/>
                        </VBox>

                        <!-- Productive Day -->
                        <VBox styleClass="insight-card" HBox.hgrow="ALWAYS">
                            <padding>
                                <Insets top="24" right="24" bottom="24" left="24"/>
                            </padding>

                            <HBox spacing="12" alignment="CENTER_LEFT">
                                <Label text="📅" styleClass="insight-icon"/>
                                <Label text="Jour le Plus Productif"
                                       styleClass="insight-label"/>
                            </HBox>

                            <Label fx:id="productiveDayValue"
                                   text="---"
                                   styleClass="insight-value"/>

                            <Label text="Optimisez votre semaine en fonction de ce jour"
                                   styleClass="insight-hint"/>
                        </VBox>

                    </HBox>

                    <!-- ============================================
                         TASK TYPE PERFORMANCE (Fixed visibility)
                         ============================================ -->
                    <HBox spacing="12" alignment="CENTER_LEFT">
                        <StackPane style="-fx-background-color: linear-gradient(to right, #f59e0b, #fbbf24);
                                           -fx-background-radius: 10; -fx-min-width: 36; -fx-min-height: 36;">
                            <Label text="📌" style="-fx-font-size: 18px;"/>
                        </StackPane>
                        <Label text="Performance par Type de Tâche"
                               styleClass="section-title"/>
                    </HBox>

                    <VBox fx:id="taskTypeStats"
                          spacing="12"
                          styleClass="task-type-container">
                        <padding>
                            <Insets top="22" right="22" bottom="22" left="22"/>
                        </padding>

                        <!-- Example task type item - High contrast badges -->
                        <HBox styleClass="task-type-item" spacing="16" alignment="CENTER_LEFT">
                            <StackPane style="-fx-background-color: linear-gradient(from 0% 100% to 100% 0%, #4facfe, #00f2fe);
                                               -fx-background-radius: 10; -fx-min-width: 40; -fx-min-height: 40;">
                                <Label text="💼" style="-fx-font-size: 20px;"/>
                            </StackPane>
                            <VBox spacing="2" HBox.hgrow="ALWAYS">
                                <Label text="Travail Professionnel" styleClass="task-type-name"/>
                                <Label text="85% complété • 12 tâches" styleClass="task-type-stat"/>
                            </VBox>
                            <!-- Badge with white text on solid background -->
                            <Label text="⭐ Excellent"
                                   styleClass="task-type-badge badge-excellent"/>
                        </HBox>

                        <HBox styleClass="task-type-item" spacing="16" alignment="CENTER_LEFT">
                            <StackPane style="-fx-background-color: linear-gradient(from 0% 100% to 100% 0%, #a78bfa, #8b5cf6);
                                               -fx-background-radius: 10; -fx-min-width: 40; -fx-min-height: 40;">
                                <Label text="📚" style="-fx-font-size: 20px;"/>
                            </StackPane>
                            <VBox spacing="2" HBox.hgrow="ALWAYS">
                                <Label text="Apprentissage" styleClass="task-type-name"/>
                                <Label text="72% complété • 8 tâches" styleClass="task-type-stat"/>
                            </VBox>
                            <Label text="📈 En progrès"
                                   styleClass="task-type-badge badge-progress"/>
                        </HBox>

                        <HBox styleClass="task-type-item" spacing="16" alignment="CENTER_LEFT">
                            <StackPane style="-fx-background-color: linear-gradient(from 0% 100% to 100% 0%, #f59e0b, #fbbf24);
                                               -fx-background-radius: 10; -fx-min-width: 40; -fx-min-height: 40;">
                                <Label text="🏃" style="-fx-font-size: 20px;"/>
                            </StackPane>
                            <VBox spacing="2" HBox.hgrow="ALWAYS">
                                <Label text="Sport &amp; Bien-être" styleClass="task-type-name"/>
                                <Label text="60% complété • 5 tâches" styleClass="task-type-stat"/>
                            </VBox>
                            <Label text="💪 À améliorer"
                                   styleClass="task-type-badge badge-improve"/>
                        </HBox>
                    </VBox>

                    <!-- ============================================
                         AI SUMMARY SECTION
                         ============================================ -->
                    <HBox spacing="12" alignment="CENTER_LEFT">
                        <StackPane style="-fx-background-color: linear-gradient(to right, #10b981, #34d399);
                                           -fx-background-radius: 10; -fx-min-width: 36; -fx-min-height: 36;">
                            <Label text="📝" style="-fx-font-size: 18px;"/>
                        </StackPane>
                        <Label text="Résumé IA"
                               styleClass="section-title"/>
                    </HBox>

                    <VBox styleClass="summary-card">
                        <padding>
                            <Insets top="24" right="24" bottom="24" left="24"/>
                        </padding>

                        <HBox spacing="10" alignment="CENTER_LEFT" style="-fx-padding: 0 0 12 0;">
                            <StackPane style="-fx-background-color: linear-gradient(from 0% 100% to 100% 0%, #10b981, #34d399);
                                               -fx-background-radius: 10; -fx-min-width: 32; -fx-min-height: 32;">
                                <Label text="🤖" style="-fx-font-size: 16px;"/>
                            </StackPane>
                            <Label text="Analyse générée par intelligence artificielle"
                                   style="-fx-font-size: 13px; -fx-text-fill: #10b981; -fx-font-weight: 600;"/>
                        </HBox>

                        <TextArea fx:id="summaryArea"
                                  wrapText="true"
                                  editable="false"
                                  prefHeight="160"
                                  styleClass="summary-text-area"
                                  text="Entrain de réflaichir ... Merci d'attendre"/>
                    </VBox>

                    <!-- ============================================
                         ADVICE SECTION
                         ============================================ -->
                    <HBox spacing="12" alignment="CENTER_LEFT">
                        <StackPane style="-fx-background-color: linear-gradient(to right, #f59e0b, #fbbf24);
                                           -fx-background-radius: 10; -fx-min-width: 36; -fx-min-height: 36;">
                            <Label text="💡" style="-fx-font-size: 18px;"/>
                        </StackPane>
                        <Label text="Conseils Personnalisés"
                               styleClass="section-title"/>
                    </HBox>

                    <VBox styleClass="advice-card">
                        <padding>
                            <Insets top="24" right="24" bottom="24" left="24"/>
                        </padding>

                        <HBox spacing="10" alignment="CENTER_LEFT" style="-fx-padding: 0 0 12 0;">
                            <StackPane style="-fx-background-color: linear-gradient(from 0% 100% to 100% 0%, #f59e0b, #fbbf24);
                                               -fx-background-radius: 10; -fx-min-width: 32; -fx-min-height: 32;">
                                <Label text="✨" style="-fx-font-size: 16px;"/>
                            </StackPane>
                            <Label text="Recommandations basées sur vos habitudes"
                                   style="-fx-font-size: 13px; -fx-text-fill: #d97706; -fx-font-weight: 600;"/>
                        </HBox>

                        <TextArea fx:id="adviceArea"
                                  wrapText="true"
                                  editable="false"
                                  prefHeight="160"
                                  styleClass="advice-text-area"
                                  text="Entrain de réflaichir ... Merci d'attendre"/>
                    </VBox>

                    <!-- ============================================
                         ACTION BUTTONS
                         ============================================ -->
                    <HBox spacing="16" alignment="CENTER_RIGHT" style="-fx-padding: 8 0 16 0;">

                        <Button text="📄 Export PDF"
                                onAction="#handleExport"
                                styleClass="secondary-button"/>

                        <Button text="🔄 Rafraîchir"
                                onAction="#handleRefresh"
                                styleClass="secondary-button"/>

                        <Button text="✕ Fermer"
                                onAction="#handleClose"
                                styleClass="primary-button"/>
                    </HBox>

                </VBox>
            </ScrollPane>

        </VBox>

    </children>
</AnchorPane>