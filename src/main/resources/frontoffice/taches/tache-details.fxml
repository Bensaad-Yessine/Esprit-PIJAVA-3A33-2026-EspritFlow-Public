<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<HBox xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
      stylesheets="@tache-details.css"
      fx:controller="piJava.Controllers.frontoffice.taches.TachesDetailsController"
      styleClass="root-bg" prefWidth="1400" prefHeight="900">

    <ScrollPane fitToWidth="true" styleClass="page-scroll" HBox.hgrow="ALWAYS">
        <VBox styleClass="main-container" maxWidth="1200" alignment="TOP_CENTER">

            <!-- Navigation Header -->
            <HBox styleClass="nav-header">
                <Button fx:id="btnBack" text="← Retour aux tâches" onAction="#handleBack" styleClass="btn-back"/>
            </HBox>

            <!-- Hero Section: Title & Main Info (No duplicate IDs here) -->
            <VBox styleClass="hero-card" spacing="20">
                <HBox spacing="16" alignment="CENTER_LEFT">
                    <Label fx:id="lblType" text="Type" styleClass="badge, type-badge"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <HBox styleClass="badge-container">
                        <Label fx:id="lblStatus" text="Statut" styleClass="badge"/>
                        <Label fx:id="lblPriority" text="Priorité" styleClass="badge"/>
                    </HBox>
                </HBox>

                <VBox spacing="12">
                    <Label fx:id="lblTitle" text="Titre de la tâche" styleClass="title-value" wrapText="true"/>
                    <Label fx:id="lblDescription" text="Description détaillée de la tâche..."
                           styleClass="description-value" wrapText="true"/>
                </VBox>

                <!-- Quick Stats Preview (No fx:id here - just visual summary) -->
                <HBox spacing="40" style="-fx-padding: 16 0 0 0;">
                    <HBox styleClass="metadata-row" spacing="8">
                        <Label text="📅" styleClass="metadata-icon"/>
                        <VBox>
                            <Label text="Planifié du" styleClass="field-label"/>
                            <Label text="Voir détails ci-dessous →" style="-fx-text-fill: #DC2626; -fx-font-weight: 600;"/>
                        </VBox>
                    </HBox>
                    <HBox styleClass="metadata-row" spacing="8">
                        <Label text="⏱" styleClass="metadata-icon"/>
                        <VBox>
                            <Label text="Durée" styleClass="field-label"/>
                            <Label text="Détails dans la section infos" style="-fx-text-fill: #6B7280;"/>
                        </VBox>
                    </HBox>
                    <HBox styleClass="metadata-row" spacing="8">
                        <Label text="📊" styleClass="metadata-icon"/>
                        <VBox>
                            <Label text="Progression" styleClass="field-label"/>
                            <Label text="Section prédiction" style="-fx-text-fill: #6B7280;"/>
                        </VBox>
                    </HBox>
                </HBox>
            </VBox>

            <!-- Main Content Split -->
            <HBox spacing="30" VBox.vgrow="ALWAYS">

                <!-- Left Column: Details & Comments (70%) -->
                <VBox spacing="24" HBox.hgrow="ALWAYS" prefWidth="700">

                    <!-- Prediction Card -->
                    <VBox styleClass="info-card" spacing="16">
                        <Label text="📊 Prédiction de réussite" styleClass="section-title"/>
                        <HBox spacing="20" alignment="CENTER_LEFT">
                            <ProgressBar fx:id="progressPrediction" prefWidth="300" prefHeight="12" HBox.hgrow="ALWAYS"/>
                            <Label fx:id="lblPrediction" text="0%" styleClass="prediction-text" minWidth="60"/>
                        </HBox>
                        <Label text="Basé sur l'analyse historique des tâches similaires"
                               style="-fx-text-fill: #9CA3AF; -fx-font-size: 12px; -fx-font-style: italic;"/>
                    </VBox>

                    <!-- Dates Grid (Unique IDs only here) -->
                    <GridPane styleClass="info-card" hgap="30" vgap="20">
                        <columnConstraints>
                            <ColumnConstraints percentWidth="50"/>
                            <ColumnConstraints percentWidth="50"/>
                        </columnConstraints>

                        <VBox styleClass="grid-cell" GridPane.columnIndex="0" GridPane.rowIndex="0">
                            <Label text="Date de début effective" styleClass="field-label"/>
                            <Label fx:id="lblDateDebut" text="Non définie" styleClass="field-value"/>
                        </VBox>

                        <VBox styleClass="grid-cell" GridPane.columnIndex="1" GridPane.rowIndex="0">
                            <Label text="Date de fin" styleClass="field-label"/>
                            <Label fx:id="lblDateFin" text="Non définie" styleClass="field-value"/>
                        </VBox>

                        <VBox styleClass="grid-cell" GridPane.columnIndex="0" GridPane.rowIndex="1">
                            <Label text="Date d'échéance" styleClass="field-label"/>
                            <Label fx:id="lblDateEcheance" text="Non définie" styleClass="field-value"/>
                        </VBox>

                        <VBox styleClass="grid-cell" GridPane.columnIndex="1" GridPane.rowIndex="1">
                            <Label text="Durée totale estimée" styleClass="field-label"/>
                            <Label fx:id="lblDureeEstimee" text="Non estimée" styleClass="field-value"/>
                        </VBox>
                    </GridPane>

                    <!-- Comments Section (Static for now) -->
                    <VBox styleClass="comments-card" spacing="16">
                        <Label text="💬 Notes et Commentaires" styleClass="section-title"/>
                        <TextArea promptText="Ajoutez des notes ou commentaires concernant cette tâche..."
                                  wrapText="true" prefRowCount="4" styleClass="comments-textarea"/>
                        <HBox alignment="CENTER_RIGHT">
                            <Button text="Sauvegarder la note" styleClass="btn-back"
                                    style="-fx-background-color: #DC2626; -fx-text-fill: white; -fx-border-color: transparent;"/>
                        </HBox>
                    </VBox>

                </VBox>

                <!-- Right Column: Actions & History (30%) -->
                <VBox spacing="24" prefWidth="280" minWidth="280">

                    <!-- Action Panel -->
                    <VBox styleClass="action-panel" alignment="CENTER">
                        <Label text="Actions" style="-fx-font-size: 18px; -fx-font-weight: 800; -fx-text-fill: #18181B; -fx-padding: 0 0 12 0;"/>
                        <Separator style="-fx-padding: 0 0 12 0;" styleClass="divider"/>

                        <Button fx:id="btnStart" text="Démarrer" styleClass="action-btn, start-btn"
                                onAction="#handleStartAction" managed="false" visible="false">
                            <graphic><Label text="▶" styleClass="button-icon"/></graphic>
                        </Button>

                        <Button fx:id="btnPause" text="Mettre en pause" styleClass="action-btn, pause-btn"
                                onAction="#handlePauseAction" managed="false" visible="false">
                            <graphic><Label text="⏸" styleClass="button-icon"/></graphic>
                        </Button>

                        <Button fx:id="btnFinish" text="Terminer" styleClass="action-btn, finish-btn"
                                onAction="#handleFinishAction" managed="false" visible="false">
                            <graphic><Label text="✓" styleClass="button-icon"/></graphic>
                        </Button>

                        <Button fx:id="btnAbandon" text="Abandonner" styleClass="action-btn, abandon-btn"
                                onAction="#handleAbandonAction" managed="false" visible="false">
                            <graphic><Label text="✕" styleClass="button-icon"/></graphic>
                        </Button>

                        <Button fx:id="btnNoActions" text="Tâche terminée" styleClass="action-btn, no-action-btn"
                                disable="true" managed="false" visible="false">
                            <graphic><Label text="🔒" styleClass="button-icon"/></graphic>
                        </Button>
                    </VBox>

                    <!-- History Timeline -->
                    <VBox styleClass="history-container" VBox.vgrow="ALWAYS">
                        <Label text="📜 Historique" styleClass="section-title"/>
                        <ListView fx:id="lvHistory" VBox.vgrow="ALWAYS" styleClass="history-list"/>
                    </VBox>

                </VBox>
            </HBox>

        </VBox>
    </ScrollPane>
</HBox>