<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>

<HBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="piJava.Controllers.frontoffice.group.GroupContentController"
      stylesheets="@group.css"
      prefWidth="1500" prefHeight="900"
      styleClass="root-bg">
    <ScrollPane fitToWidth="true" styleClass="page-scroll" HBox.hgrow="ALWAYS">
        <VBox spacing="26" styleClass="main-container">

            <!-- HEADER -->
            <HBox alignment="CENTER_LEFT" spacing="20">
                <VBox HBox.hgrow="ALWAYS" spacing="6">
                    <Label text="Mes Groupes" styleClass="title"/>
                    <Label text="ESPRIT Flow · Gestion des groupes de projet" styleClass="subtitle"/>
                </VBox>
                <Button fx:id="invitationsBtn" text="📩 Invitations" styleClass="btn-secondary" onAction="#handleInvitations"/>
                <Button fx:id="addGroupBtn" text="＋ Nouveau Groupe" styleClass="btn-primary" onAction="#handleAdd"/>
            </HBox>

            <!-- 3 STAT CARDS -->
            <HBox spacing="20">

                <VBox HBox.hgrow="ALWAYS" prefHeight="140"
                      spacing="8" alignment="TOP_LEFT"
                      styleClass="red-card">
                    <Label text="📚  Total Groupes" styleClass="card-label"/>
                    <Label fx:id="totalGroupsLabel" text="0" styleClass="card-number"/>
                    <Label text="Tous les groupes" styleClass="card-sub"/>
                </VBox>

                <VBox HBox.hgrow="ALWAYS" prefHeight="140"
                      spacing="8" alignment="TOP_LEFT"
                      styleClass="red-card-light">
                    <Label text="✓  Actifs" styleClass="card-label"/>
                    <Label fx:id="activeGroupsLabel" text="0" styleClass="card-number"/>
                    <Label text="En cours" styleClass="card-sub"/>
                </VBox>

                <VBox HBox.hgrow="ALWAYS" prefHeight="140"
                      spacing="8" alignment="TOP_LEFT"
                      styleClass="red-card-mid">
                    <Label text="⏳  Inactifs" styleClass="card-label"/>
                    <Label fx:id="pendingGroupsLabel" text="0" styleClass="card-number"/>
                    <Label text="Fermés" styleClass="card-sub"/>
                </VBox>

            </HBox>

            <!-- SEARCH -->
            <HBox spacing="20" styleClass="filter-card">
                <VBox spacing="8" HBox.hgrow="ALWAYS">
                    <Label text="🔍 Rechercher" styleClass="filter-label"/>
                    <TextField fx:id="searchField" promptText="Nom du groupe ou projet..." styleClass="search-field"/>
                </VBox>
            </HBox>

            <!-- GROUPS LIST -->
            <VBox spacing="12">
                <HBox alignment="CENTER_LEFT" spacing="12">
                    <Label text="📌 Mes Groupes" styleClass="panel-title" HBox.hgrow="ALWAYS"/>
                    <Label fx:id="footerLabel" text="0 groupes" styleClass="task-count"/>
                </HBox>

                <ScrollPane fitToWidth="true" styleClass="task-scroll" prefHeight="400">
                    <VBox fx:id="groupsContainer" spacing="16" styleClass="tasks-container"/>
                </ScrollPane>
            </VBox>

        </VBox>
    </ScrollPane>

</HBox>
