<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.shape.Rectangle?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="piJava.Controllers.frontoffice.emploi.ScanQRCodeController"
      alignment="CENTER"
      spacing="20"
      style="-fx-background-color: #0f172a; -fx-padding: 40;"
      prefWidth="600" prefHeight="700">

    <!-- Header Icon -->
    <VBox alignment="CENTER" spacing="10">
        <StackPane style="-fx-background-color: #3b82f6; -fx-background-radius: 50; -fx-min-width: 60; -fx-min-height: 60; -fx-max-width: 60; -fx-max-height: 60;">
            <Label text="📸" style="-fx-font-size: 24px;"/>
        </StackPane>
        <Label text="Marquer ma présence" style="-fx-text-fill: white; -fx-font-size: 22px; -fx-font-weight: bold;"/>
        <Label text="Veuillez scanner le QR Code affiché par l'enseignant" style="-fx-text-fill: #94a3b8; -fx-font-size: 13px;"/>
    </VBox>

    <!-- Camera Container -->
    <VBox alignment="CENTER" spacing="15" 
          style="-fx-background-color: #1e293b; -fx-background-radius: 15; -fx-padding: 20; -fx-border-color: #334155; -fx-border-radius: 15;">
        
        <Label text="Scanner Le QR Code" style="-fx-text-fill: white; -fx-font-size: 14px;"/>
        
        <StackPane>
            <Rectangle width="400" height="300" style="-fx-fill: #000000; -fx-arc-width: 15; -fx-arc-height: 15;"/>
            <ImageView fx:id="cameraView" fitWidth="400" fitHeight="300" preserveRatio="true"/>
            
            <!-- Scan Overlay/Frame -->
            <Rectangle fx:id="overlayRect" width="200" height="200" style="-fx-fill: transparent; -fx-stroke: #3b82f6; -fx-stroke-width: 3; -fx-arc-width: 10; -fx-arc-height: 10; -fx-stroke-dash-array: 10 5;"/>
            
            <Label text="Centrez le QR code dans le cadre" style="-fx-text-fill: white; -fx-background-color: rgba(0,0,0,0.5); -fx-padding: 5 10; -fx-background-radius: 10;" StackPane.alignment="BOTTOM_CENTER"/>
        </StackPane>

        <Label fx:id="lblStatus" text="Caméra prête – Recherche du QR Code..." style="-fx-text-fill: #3b82f6; -fx-font-weight: bold; -fx-font-size: 13px;"/>
    </VBox>

    <!-- Controls -->
    <VBox alignment="CENTER" spacing="15" style="-fx-padding: 10 0 0 0;">
        <Button fx:id="btnConfirmer" text="Annuler" onAction="#handleConfirmer"
                style="-fx-background-color: #8b5cf6; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 12 40; -fx-background-radius: 8; -fx-cursor: hand; -fx-font-size: 14px;"/>
    </VBox>

</VBox>
