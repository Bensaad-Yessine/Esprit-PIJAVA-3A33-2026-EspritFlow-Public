<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.shape.*?>
<?import javafx.scene.image.*?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="piJava.Controllers.frontoffice.FrontSidebarController"
      styleClass="front-sidebar"
      minWidth="270" prefWidth="270" maxWidth="270"
      spacing="0"
      stylesheets="@front-sidebar.css">

    <!-- ═══ LOGO ═══ -->
    <HBox styleClass="f-logo-container" alignment="CENTER_LEFT" spacing="10">
        <StackPane styleClass="f-logo-mark">
            <Label text="EF" styleClass="f-logo-mark-text"/>
        </StackPane>
        <VBox spacing="1">
            <Label text="ESPRIT FLOW" styleClass="f-logo-title"/>
            <Label text="Espace Étudiant" styleClass="f-logo-subtitle"/>
        </VBox>
    </HBox>

    <!-- ═══ PROFILE / SESSION ═══ -->
    <VBox styleClass="f-profile-section" spacing="8">

        <HBox alignment="CENTER_LEFT" spacing="12" onMouseClicked="#goToProfile">
            <StackPane fx:id="avatarStack" minWidth="48" minHeight="48"
                       maxWidth="48" maxHeight="48" >
                <Circle fx:id="avatarCircle" radius="24" styleClass="f-avatar-circle"
                        centerX="24" centerY="24"/>
                <ImageView fx:id="avatarImage" fitWidth="48" fitHeight="48"
                           preserveRatio="true" visible="false"/>
                <Label fx:id="avatarInitials" text="?" styleClass="f-avatar-initials"/>
                <Circle radius="6" styleClass="f-online-dot"
                        centerX="42" centerY="42"/>
            </StackPane>

            <VBox spacing="4">
                <Label fx:id="lblProfileName" text="Chargement..." styleClass="f-profile-name"/>
                <HBox styleClass="f-role-badge" alignment="CENTER_LEFT" spacing="5">
                    <Circle radius="3" styleClass="f-badge-dot"/>
                    <Label fx:id="roleBadgeLabel" text="ÉTUDIANT" styleClass="f-badge-text"/>
                </HBox>
            </VBox>
        </HBox>

        <HBox spacing="6">
            <VBox styleClass="f-info-cell" HBox.hgrow="ALWAYS">
                <Label text="Prénom" styleClass="f-info-label"/>
                <Label fx:id="profilePrenom" text="—" styleClass="f-info-value"/>
            </VBox>
            <VBox styleClass="f-info-cell" HBox.hgrow="ALWAYS">
                <Label text="Nom" styleClass="f-info-label"/>
                <Label fx:id="profileNom" text="—" styleClass="f-info-value"/>
            </VBox>
        </HBox>

        <VBox styleClass="f-info-cell">
            <Label text="Email" styleClass="f-info-label"/>
            <Label fx:id="profileEmail" text="—" styleClass="f-info-value"/>
        </VBox>

        <HBox spacing="6">
            <VBox styleClass="f-info-cell" HBox.hgrow="ALWAYS">
                <Label text="Rôle" styleClass="f-info-label"/>
                <Label fx:id="lblProfileRole" text="—" styleClass="f-info-value"/>
            </VBox>
            <VBox styleClass="f-info-cell" HBox.hgrow="ALWAYS">
                <Label text="Session" styleClass="f-info-label"/>
                <HBox alignment="CENTER_LEFT" spacing="5">
                    <Circle radius="4" styleClass="f-session-live-dot"/>
                    <Label fx:id="sessionStatus" text="En ligne" styleClass="f-info-value-green"/>
                </HBox>
            </VBox>
        </HBox>

    </VBox>

    <!-- ═══ NAVIGATION ═══ -->
    <ScrollPane styleClass="f-nav-scroll" fitToWidth="true" VBox.vgrow="ALWAYS"
                hbarPolicy="NEVER" vbarPolicy="AS_NEEDED">
        <VBox styleClass="f-nav-container" spacing="1">

            <Label text="MENU PRINCIPAL" styleClass="f-nav-section-title"/>

            <HBox fx:id="dashboardBtn" styleClass="f-nav-item" alignment="CENTER_LEFT"
                  spacing="9" onMouseClicked="#goToDashboard">
                <StackPane styleClass="f-nav-icon-wrap">
                    <Label styleClass="f-nav-icon-label" text="&#8962;"/>
                </StackPane>
                <Label text="Tableau de bord" styleClass="f-nav-item-label" HBox.hgrow="ALWAYS"/>
            </HBox>

            <HBox fx:id="tachesBtn" styleClass="f-nav-item" alignment="CENTER_LEFT"
                  spacing="9" onMouseClicked="#goToTaches">
                <StackPane styleClass="f-nav-icon-wrap">
                    <Label styleClass="f-nav-icon-label" text="&#10003;"/>
                </StackPane>
                <Label text="Tâches" styleClass="f-nav-item-label" HBox.hgrow="ALWAYS"/>
            </HBox>

            <HBox fx:id="classesBtn" styleClass="f-nav-item" alignment="CENTER_LEFT"
                  spacing="9" onMouseClicked="#goToClasses">
                <StackPane styleClass="f-nav-icon-wrap">
                    <Label styleClass="f-nav-icon-label" text="&#9638;"/>
                </StackPane>
                <Label text="Groupes et Classes" styleClass="f-nav-item-label" HBox.hgrow="ALWAYS"/>
            </HBox>

            <HBox fx:id="matieresBtn" styleClass="f-nav-item" alignment="CENTER_LEFT"
                  spacing="9" onMouseClicked="#goToMatieres">
                <StackPane styleClass="f-nav-icon-wrap">
                    <Label styleClass="f-nav-icon-label" text="&#128218;"/>
                </StackPane>
                <Label text="Cours et Programmes" styleClass="f-nav-item-label" HBox.hgrow="ALWAYS"/>
            </HBox>

            <HBox fx:id="enseignantsBtn" styleClass="f-nav-item" alignment="CENTER_LEFT"
                  spacing="9" onMouseClicked="#goToEnseignants">
                <StackPane styleClass="f-nav-icon-wrap">
                    <Label styleClass="f-nav-icon-label" text="&#127891;"/>
                </StackPane>
                <Label text="Intervenants" styleClass="f-nav-item-label" HBox.hgrow="ALWAYS"/>
            </HBox>

            <Label text="GESTION DES OPÉRATIONS" styleClass="f-nav-section-title"/>

            <HBox fx:id="emploiBtn" styleClass="f-nav-item" alignment="CENTER_LEFT"
                  spacing="9" onMouseClicked="#goToEmploi">
                <StackPane styleClass="f-nav-icon-wrap">
                    <Label styleClass="f-nav-icon-label" text="&#128197;"/>
                </StackPane>
                <Label text="Séances" styleClass="f-nav-item-label" HBox.hgrow="ALWAYS"/>
            </HBox>

            <HBox fx:id="sallesBtn" styleClass="f-nav-item" alignment="CENTER_LEFT"
                  spacing="9" onMouseClicked="#goToSalles">
                <StackPane styleClass="f-nav-icon-wrap">
                    <Label styleClass="f-nav-icon-label" text="&#127970;"/>
                </StackPane>
                <Label text="Salles" styleClass="f-nav-item-label" HBox.hgrow="ALWAYS"/>
            </HBox>



            <HBox fx:id="ObjectifsSante" styleClass="f-nav-item" alignment="CENTER_LEFT"
                  spacing="9" onMouseClicked="#goToObjectifsSante">
                <StackPane styleClass="f-nav-icon-wrap">
                    <Label styleClass="f-nav-icon-label" text="&#128221;"/>
                </StackPane>
                <Label text="Évaluations" styleClass="f-nav-item-label" HBox.hgrow="ALWAYS"/>
            </HBox>

            <Label text="COMMUNICATION" styleClass="f-nav-section-title"/>

            <HBox fx:id="notificationsBtn" styleClass="f-nav-item" alignment="CENTER_LEFT"
                  spacing="9" onMouseClicked="#goToNotifications">
                <StackPane styleClass="f-nav-icon-wrap">
                    <Label styleClass="f-nav-icon-label" text="&#128276;"/>
                </StackPane>
                <Label text="Notifications et Alertes" styleClass="f-nav-item-label" HBox.hgrow="ALWAYS"/>
                <Label fx:id="notifBadge" text="3" styleClass="f-nav-badge f-nav-badge-red"/>
            </HBox>

        </VBox>
    </ScrollPane>

    <!-- ═══ LOGOUT ═══ -->
    <VBox styleClass="f-logout-section">
        <HBox fx:id="logoutBtn" styleClass="f-logout-item" alignment="CENTER_LEFT"
              spacing="9" onMouseClicked="#logout">
            <StackPane styleClass="f-nav-icon-wrap f-logout-icon-wrap">
                <Label styleClass="f-nav-icon-label f-logout-icon-label" text="&#9211;"/>
            </StackPane>
            <Label text="Déconnexion" styleClass="f-logout-label"/>
        </HBox>
    </VBox>

</VBox>