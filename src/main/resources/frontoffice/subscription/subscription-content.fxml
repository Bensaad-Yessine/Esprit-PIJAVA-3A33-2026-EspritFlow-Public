<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<HBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="piJava.Controllers.frontoffice.subscription.SubscriptionContentController"
      stylesheets="@subscription.css"
      prefWidth="1500" prefHeight="900"
      styleClass="root-bg">

    <ScrollPane fitToWidth="true" styleClass="page-scroll" HBox.hgrow="ALWAYS">
        <content>
            <VBox spacing="26" styleClass="main-container">
                <padding>
                    <Insets top="24" right="24" bottom="24" left="24"/>
                </padding>

                <HBox alignment="CENTER_LEFT" spacing="20">
                    <VBox HBox.hgrow="ALWAYS" spacing="6">
                        <Label fx:id="titleLabel" text="Abonnements et paiement Stripe" styleClass="title"/>
                        <Label fx:id="subtitleLabel" text="Choisissez un pack et payez en toute sécurité via Stripe Checkout." styleClass="subtitle"/>
                    </VBox>
                    <Button text="↻ Rafraîchir" onAction="#handleReload" styleClass="btn-primary"/>
                </HBox>

                <HBox spacing="20" styleClass="hero-card">
                    <VBox spacing="8" HBox.hgrow="ALWAYS">
                        <Label text="Abonnements et paiement Stripe" styleClass="hero-title"/>
                        <Label text="Un design harmonisé avec le reste du front office, en rouge et blanc." wrapText="true" styleClass="hero-subtitle"/>
                    </VBox>
                    <Label text="💳" styleClass="hero-sticker"/>
                </HBox>

                <VBox spacing="14" styleClass="panel">
                    <HBox alignment="CENTER_LEFT" spacing="12">
                        <Label text="Packs disponibles" styleClass="panel-title" HBox.hgrow="ALWAYS"/>
                        <Label fx:id="statusLabel" text="Prêt à payer" styleClass="badge-blue"/>
                    </HBox>
                    <Label fx:id="summaryLabel" text="Connecté" styleClass="subscription-summary"/>
                    <Label fx:id="messageLabel" text="" wrapText="true" styleClass="subscription-message"/>

                    <FlowPane fx:id="packsContainer" hgap="18" vgap="18" prefWrapLength="1200" styleClass="subscription-grid"/>
                </VBox>
            </VBox>
        </content>
    </ScrollPane>
</HBox>

