<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.*?>
<?import java.util.*?>
<?import javafx.scene.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<?import javafx.geometry.Insets?>
<AnchorPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="piJava.Controllers.frontoffice.preferencealerte.AlerteEditController"
            stylesheets="@alerte-edit.css"
            prefHeight="750.0" prefWidth="900.0"
            styleClass="root">

    <ScrollPane fitToWidth="true" fitToHeight="true" hbarPolicy="NEVER" vbarPolicy="AS_NEEDED"
                AnchorPane.topAnchor="0" AnchorPane.bottomAnchor="0"
                AnchorPane.leftAnchor="0" AnchorPane.rightAnchor="0"
                styleClass="main-scroll">
        <VBox spacing="0" styleClass="form-wrapper" maxWidth="Infinity">

            <!-- Hero Header -->
            <VBox styleClass="hero-header" spacing="15">
                <padding>
                    <Insets top="30" right="40" bottom="30" left="40"/>
                </padding>
                <Label text="✏️ Modifier la Préférence Alerte" styleClass="hero-title"/>
                <Label text="Modifiez les paramètres de votre alerte" styleClass="hero-subtitle"/>
            </VBox>

            <!-- Main Form Container -->
            <VBox spacing="25" styleClass="form-container">
                <padding>
                    <Insets top="35" right="40" bottom="40" left="40"/>
                </padding>

                <!-- Form Section -->
                <VBox spacing="20" styleClass="glass-card">
                    <padding>
                        <Insets top="30" right="35" bottom="30" left="35"/>
                    </padding>

                    <!-- Section Header -->
                    <HBox spacing="12" alignment="CENTER_LEFT" styleClass="section-header">
                        <Label text="📝" styleClass="section-icon"/>
                        <Label text="Informations Générales" styleClass="section-title"/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <Label text="* Champs obligatoires" styleClass="required-hint"/>
                    </HBox>

                    <GridPane hgap="25" vgap="20" styleClass="form-grid" VBox.vgrow="ALWAYS">
                        <columnConstraints>
                            <ColumnConstraints minWidth="150" prefWidth="180" maxWidth="200"/>
                            <ColumnConstraints hgrow="ALWAYS" minWidth="300"/>
                        </columnConstraints>

                        <!-- Nom -->
                        <Label text="Nom *" GridPane.rowIndex="0" GridPane.columnIndex="0" styleClass="form-label"/>
                        <VBox GridPane.rowIndex="0" GridPane.columnIndex="1" spacing="6">
                            <TextField fx:id="nomField" promptText="Entrez le nom de l'alerte" styleClass="modern-field"/>
                            <Label fx:id="nomErrorLabel" styleClass="error-label"/>
                        </VBox>

                        <!-- Description -->
                        <Label text="Description" GridPane.rowIndex="1" GridPane.columnIndex="0" styleClass="form-label"/>
                        <VBox GridPane.rowIndex="1" GridPane.columnIndex="1" spacing="6">
                            <TextArea fx:id="descriptionField" promptText="Décrivez le but de cette alerte..."
                                      prefRowCount="3" wrapText="true" styleClass="modern-textarea"/>
                            <Label fx:id="descriptionErrorLabel" styleClass="error-label"/>
                        </VBox>

                        <!-- Délai -->
                        <Label text="Délai (min) *" GridPane.rowIndex="2" GridPane.columnIndex="0" styleClass="form-label"/>
                        <VBox GridPane.rowIndex="2" GridPane.columnIndex="1" spacing="6">
                            <TextField fx:id="delaiField" promptText="Ex: 30" styleClass="modern-field"/>
                            <Label fx:id="delaiErrorLabel" styleClass="error-label"/>
                        </VBox>

                        <!-- Heure début -->
                        <Label text="Heure silence début" GridPane.rowIndex="3" GridPane.columnIndex="0" styleClass="form-label"/>
                        <VBox GridPane.rowIndex="3" GridPane.columnIndex="1" spacing="6">
                            <TextField fx:id="debutField" promptText="HH:mm:ss" styleClass="modern-field time-field"/>
                            <Label fx:id="debutErrorLabel" styleClass="error-label"/>
                        </VBox>

                        <!-- Heure fin -->
                        <Label text="Heure silence fin" GridPane.rowIndex="4" GridPane.columnIndex="0" styleClass="form-label"/>
                        <VBox GridPane.rowIndex="4" GridPane.columnIndex="1" spacing="6">
                            <TextField fx:id="finField" promptText="HH:mm:ss" styleClass="modern-field time-field"/>
                            <Label fx:id="finErrorLabel" styleClass="error-label"/>
                        </VBox>
                    </GridPane>
                </VBox>

                <!-- Options Section -->
                <VBox spacing="20" styleClass="glass-card accent-card">
                    <padding>
                        <Insets top="30" right="35" bottom="30" left="35"/>
                    </padding>

                    <HBox spacing="12" alignment="CENTER_LEFT" styleClass="section-header">
                        <Label text="⚙️" styleClass="section-icon"/>
                        <Label text="Options de Notification" styleClass="section-title"/>
                        <Region HBox.hgrow="ALWAYS"/>
                    </HBox>

                    <HBox spacing="30" styleClass="checkbox-wrapper">
                        <VBox spacing="15" styleClass="checkbox-group">
                            <Label text="État" styleClass="group-label"/>
                            <CheckBox fx:id="activeCheck" text="Activer cette alerte" styleClass="modern-checkbox"/>
                            <CheckBox fx:id="defaultCheck" text="Définir par défaut" styleClass="modern-checkbox"/>
                        </VBox>

                        <VBox spacing="15" styleClass="checkbox-group">
                            <Label text="Canaux" styleClass="group-label"/>
                            <CheckBox fx:id="emailCheck" text="📧 Notifications Email" styleClass="modern-checkbox"/>
                            <CheckBox fx:id="pushCheck" text="📱 Notifications Push" styleClass="modern-checkbox"/>
                            <CheckBox fx:id="siteCheck" text="🌐 Notifications Site Web" styleClass="modern-checkbox"/>
                        </VBox>
                    </HBox>
                </VBox>

                <!-- Action Buttons -->
                <HBox spacing="20" alignment="CENTER_RIGHT" styleClass="button-bar">
                    <padding>
                        <Insets top="10" right="0" bottom="0" left="0"/>
                    </padding>
                    <Button text="❌ Annuler" onAction="#handleCancel" styleClass="btn-glass-cancel"/>
                    <Button text="💾 Enregistrer" onAction="#handleUpdate" styleClass="btn-glass-success"/>
                </HBox>

            </VBox>
        </VBox>
    </ScrollPane>

</AnchorPane>