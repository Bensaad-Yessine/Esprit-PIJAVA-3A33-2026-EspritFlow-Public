<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.shape.*?>
<?import javafx.geometry.Insets?>

<ScrollPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="piJava.Controllers.frontoffice.salle.FrontSallesController"
            styleClass="salle-list-container"
            fitToWidth="true"
            stylesheets="@front_salles.css">

    <VBox spacing="40" styleClass="main-container">

        <!-- HEADER SECTION -->
        <HBox alignment="CENTER_LEFT" spacing="20">
            <VBox spacing="5" HBox.hgrow="ALWAYS">
                <Label text="Salles disponibles" styleClass="page-title"/>
                <Label text="Consultez les salles disponibles par bloc et étage" styleClass="page-subtitle"/>
                <Region prefHeight="3" maxWidth="80" styleClass="title-underline">
                    <VBox.margin><Insets top="15"/></VBox.margin>
                </Region>
            </VBox>

            <!-- SESSION ACTUELLE CARD -->
            <VBox styleClass="session-card" alignment="CENTER" spacing="10">
                <Label text="SESSION ACTUELLE" styleClass="session-badge-title"/>
                <Label fx:id="lblSessionEmail" text="chargement..." styleClass="session-email"/>
                <HBox alignment="CENTER" spacing="8">
                    <Circle radius="4" fill="#10b981"/>
                    <Button text="🗺 Map" styleClass="map-btn" onAction="#handleMapClick"/>
                </HBox>
            </VBox>
        </HBox>

        <!-- STATS SECTION -->
        <HBox spacing="30">
            <!-- Stat 1 -->
            <HBox styleClass="stat-card" spacing="20" alignment="CENTER_LEFT" HBox.hgrow="ALWAYS">
                <StackPane styleClass="stat-icon-pane" minWidth="48" minHeight="48" maxWidth="48" maxHeight="48">
                    <Label text="🏢" style="-fx-font-size: 20px;"/>
                </StackPane>
                <VBox spacing="2">
                    <Label fx:id="lblTotalSalles" text="0" styleClass="stat-number"/>
                    <Label text="Total salles" styleClass="stat-label"/>
                </VBox>
            </HBox>

            <!-- Stat 2 -->
            <HBox styleClass="stat-card" spacing="20" alignment="CENTER_LEFT" HBox.hgrow="ALWAYS">
                <StackPane styleClass="stat-icon-pane" minWidth="48" minHeight="48" maxWidth="48" maxHeight="48">
                    <Label text="📦" style="-fx-font-size: 20px;"/>
                </StackPane>
                <VBox spacing="2">
                    <Label fx:id="lblTotalBlocs" text="0" styleClass="stat-number"/>
                    <Label text="Blocs" styleClass="stat-label"/>
                </VBox>
            </HBox>

            <!-- Stat 3 -->
            <HBox styleClass="stat-card" spacing="20" alignment="CENTER_LEFT" HBox.hgrow="ALWAYS">
                <StackPane styleClass="stat-icon-pane" minWidth="48" minHeight="48" maxWidth="48" maxHeight="48">
                    <Label text="📚" style="-fx-font-size: 20px;"/>
                </StackPane>
                <VBox spacing="2">
                    <Label fx:id="lblTotalEtages" text="0" styleClass="stat-number"/>
                    <Label text="Étages" styleClass="stat-label"/>
                </VBox>
            </HBox>
        </HBox>

        <!-- FILTER BAR -->
        <VBox styleClass="filter-bar" spacing="15">
            <HBox alignment="CENTER_LEFT" spacing="10">
                <Label text="🔍" styleClass="filter-title"/>
                <Label text="Filtrer les salles" styleClass="filter-title"/>
            </HBox>
            
            <HBox spacing="20" alignment="BOTTOM_LEFT">
                <VBox spacing="5" HBox.hgrow="ALWAYS">
                    <Label text="BLOC" styleClass="filter-label"/>
                    <ComboBox fx:id="comboBloc" promptText="Tous les blocs" styleClass="filter-combo" maxWidth="Infinity"/>
                </VBox>
                
                <VBox spacing="5" HBox.hgrow="ALWAYS">
                    <Label text="ÉTAGE" styleClass="filter-label"/>
                    <ComboBox fx:id="comboEtage" promptText="Tous les étages" styleClass="filter-combo" maxWidth="Infinity"/>
                </VBox>
                
                <VBox spacing="5" HBox.hgrow="ALWAYS">
                    <Label text="RECHERCHE" styleClass="filter-label"/>
                    <TextField fx:id="searchField" promptText="Nom de la salle..." styleClass="filter-text"/>
                </VBox>
                
                <VBox spacing="5" HBox.hgrow="ALWAYS">
                    <Label text="TRIER PAR" styleClass="filter-label"/>
                    <ComboBox fx:id="comboTri" promptText="Nom ↑" styleClass="filter-combo" maxWidth="Infinity"/>
                </VBox>
            </HBox>
            
            <HBox alignment="CENTER_LEFT" spacing="15">
                <Button text="Réinitialiser" styleClass="btn-reset" onAction="#resetFilters"/>
                <Label fx:id="lblCountResults" text="0 salles trouvées" style="-fx-text-fill: #9ca3af; -fx-font-size: 13px;"/>
            </HBox>
        </VBox>

        <!-- FLOW PANE FOR SALLES -->
        <FlowPane fx:id="sallesFlowPane" hgap="30" vgap="30" />

    </VBox>

</ScrollPane>
