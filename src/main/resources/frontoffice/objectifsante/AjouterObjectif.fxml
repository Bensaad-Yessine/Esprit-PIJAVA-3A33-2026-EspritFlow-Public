<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.String?>
<?import javafx.collections.FXCollections?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefHeight="720.0" prefWidth="900.0"
            xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="piJava.Controllers.frontoffice.objectifsante.AjouterObjectifController"
            stylesheets="@style.css"
            style="-fx-background-color: linear-gradient(from 0% 0% to 100% 100%, #F5F5F6, rgba(253, 120, 120, 0.94));">

    <top>
        <HBox styleClass="top-bar" spacing="12">
            <padding>
                <Insets top="16" right="24" bottom="16" left="24"/>
            </padding>
            <children>
                <VBox spacing="2">
                    <children>
                        <Label text="Esprit Flow" styleClass="top-bar-title"/>
                        <Label text="Create a new health goal" styleClass="top-bar-subtitle"/>
                    </children>
                </VBox>
                <Region HBox.hgrow="ALWAYS"/>
            </children>
        </HBox>
    </top>

    <center>
        <ScrollPane fitToWidth="true"
                    pannable="true"
                    style="-fx-background: transparent; -fx-background-color: transparent;">
            <content>
                <VBox spacing="20" style="-fx-padding: 24;">
                    <children>

                        <HBox spacing="20" styleClass="hero-card">
                            <children>
                                <VBox spacing="8" HBox.hgrow="ALWAYS">
                                    <children>
                                        <Label text="💙 Créer un nouvel objectif santé" styleClass="hero-title"/>
                                        <Label text="Définissez un objectif clair avec un type, une période et une priorité pour mieux suivre le bien-être."
                                               wrapText="true"
                                               styleClass="hero-subtitle"/>
                                    </children>
                                </VBox>
                                <Label text="🩺" styleClass="hero-sticker"/>
                            </children>
                        </HBox>

                        <VBox styleClass="card" spacing="18" VBox.vgrow="ALWAYS">
                            <children>
                                <HBox alignment="CENTER_LEFT">
                                    <children>
                                        <Label text="📝 Formulaire objectif" styleClass="label-title"/>
                                        <Region HBox.hgrow="ALWAYS"/>
                                        <Label text="Nouveau" styleClass="badge-blue"/>
                                    </children>
                                </HBox>

                                <GridPane hgap="18" vgap="18">
                                    <padding>
                                        <Insets top="10" right="10" bottom="10" left="10"/>
                                    </padding>

                                    <Label text="Titre :" styleClass="form-label" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                                    <VBox spacing="4" GridPane.rowIndex="0" GridPane.columnIndex="1">
                                        <children>
                                            <TextField fx:id="txtTitre" promptText="Entrer le titre de l'objectif"/>
                                            <Label fx:id="errTitre" styleClass="error-label"/>
                                        </children>
                                    </VBox>

                                    <Label text="Type :" styleClass="form-label" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
                                    <VBox spacing="4" GridPane.rowIndex="1" GridPane.columnIndex="1">
                                        <children>
                                            <ComboBox fx:id="cbType" prefWidth="300.0">
                                                <items>
                                                    <FXCollections fx:factory="observableArrayList">
                                                        <String fx:value="SOMMEIL"/>
                                                        <String fx:value="SPORT"/>
                                                        <String fx:value="ALIMENTATION"/>
                                                    </FXCollections>
                                                </items>
                                            </ComboBox>
                                            <Label fx:id="errType" styleClass="error-label"/>
                                        </children>
                                    </VBox>

                                    <Label text="Valeur cible :" styleClass="form-label" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
                                    <VBox spacing="4" GridPane.rowIndex="2" GridPane.columnIndex="1">
                                        <children>
                                            <HBox spacing="10">
                                                <children>
                                                    <TextField fx:id="txtValeurCible" promptText="Ex: 8" prefWidth="180.0"/>
                                                    <Label fx:id="lblUnite" text="Unité" styleClass="badge-blue"/>
                                                </children>
                                            </HBox>
                                            <Label fx:id="errValeurCible" styleClass="error-label"/>
                                        </children>
                                    </VBox>

                                    <Label text="Date début :" styleClass="form-label" GridPane.rowIndex="3" GridPane.columnIndex="0"/>
                                    <VBox spacing="4" GridPane.rowIndex="3" GridPane.columnIndex="1">
                                        <children>
                                            <DatePicker fx:id="dpDateDebut" prefWidth="300.0"/>
                                            <Label fx:id="errDateDebut" styleClass="error-label"/>
                                        </children>
                                    </VBox>

                                    <Label text="Date fin :" styleClass="form-label" GridPane.rowIndex="4" GridPane.columnIndex="0"/>
                                    <VBox spacing="4" GridPane.rowIndex="4" GridPane.columnIndex="1">
                                        <children>
                                            <DatePicker fx:id="dpDateFin" prefWidth="300.0"/>
                                            <Label fx:id="errDateFin" styleClass="error-label"/>
                                        </children>
                                    </VBox>

                                    <Label text="Priorité :" styleClass="form-label" GridPane.rowIndex="5" GridPane.columnIndex="0"/>
                                    <VBox spacing="4" GridPane.rowIndex="5" GridPane.columnIndex="1">
                                        <children>
                                            <ComboBox fx:id="cbPriorite" prefWidth="300.0">
                                                <items>
                                                    <FXCollections fx:factory="observableArrayList">
                                                        <String fx:value="BASSE"/>
                                                        <String fx:value="MOYENNE"/>
                                                        <String fx:value="HAUTE"/>
                                                    </FXCollections>
                                                </items>
                                            </ComboBox>
                                            <Label fx:id="errPriorite" styleClass="error-label"/>
                                        </children>
                                    </VBox>
                                </GridPane>

                                <HBox spacing="12" alignment="CENTER_RIGHT">
                                    <children>
                                        <Region HBox.hgrow="ALWAYS"/>
                                        <Button text="Retour"
                                                styleClass="secondary-button"
                                                onAction="#retourObjectifs"/>

                                        <Button fx:id="btnAjouter"
                                                text="Ajouter"
                                                styleClass="primary-button"
                                                onAction="#ajouterObjectif"/>
                                    </children>
                                </HBox>
                            </children>
                        </VBox>

                    </children>
                </VBox>
            </content>
        </ScrollPane>
    </center>

</BorderPane>