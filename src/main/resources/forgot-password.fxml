<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Hyperlink?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.Region?>

<AnchorPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="piJava.Controllers.ForgotPasswordController"
            prefHeight="700.0" prefWidth="1000.0"
            stylesheets="@login.css"
            styleClass="root-pane">

    <VBox alignment="CENTER" layoutX="0" layoutY="0"
          prefWidth="460" prefHeight="700"
          styleClass="brand-panel">
        <padding><Insets left="70" right="50"/></padding>

        <HBox alignment="CENTER_LEFT" spacing="12">
            <StackPane prefWidth="42" prefHeight="42" styleClass="logo-box">
                <Label text="E" styleClass="logo-letter"/>
            </StackPane>
            <Label text="EspritFlow" styleClass="logo-name"/>
            <VBox.margin><Insets bottom="48"/></VBox.margin>
        </HBox>

        <Label text="Need help?" styleClass="headline">
            <VBox.margin><Insets bottom="12"/></VBox.margin>
        </Label>
        <Label text="We will send you a reset code by email."
               styleClass="subheadline" wrapText="true">
            <VBox.margin><Insets bottom="48"/></VBox.margin>
        </Label>

        <VBox spacing="14">
            <HBox spacing="12" alignment="CENTER_LEFT">
                <StackPane prefWidth="32" prefHeight="32" styleClass="feature-icon">
                    <Label text="✉" styleClass="feature-icon-blue"/>
                </StackPane>
                <Label text="A secure reset code is sent to your mailbox" styleClass="feature-text"/>
            </HBox>
            <HBox spacing="12" alignment="CENTER_LEFT">
                <StackPane prefWidth="32" prefHeight="32" styleClass="feature-icon">
                    <Label text="⏱" styleClass="feature-icon-indigo"/>
                </StackPane>
                <Label text="The code expires automatically after 30 minutes" styleClass="feature-text"/>
            </HBox>
            <HBox spacing="12" alignment="CENTER_LEFT">
                <StackPane prefWidth="32" prefHeight="32" styleClass="feature-icon">
                    <Label text="🔒" styleClass="feature-icon-red"/>
                </StackPane>
                <Label text="Your password stays hashed and secure" styleClass="feature-text"/>
            </HBox>
        </VBox>
    </VBox>

    <Region layoutX="460" layoutY="60" prefWidth="1" prefHeight="580" styleClass="divider"/>

    <VBox alignment="TOP_LEFT"
          layoutX="500" layoutY="60"
          prefWidth="430"
          styleClass="login-card">

        <Label text="Forgot password"
               styleClass="card-title">
            <VBox.margin><Insets bottom="4"/></VBox.margin>
        </Label>
        <Label text="Enter your email address and we will send you a reset code"
               styleClass="card-subtitle">
            <VBox.margin><Insets bottom="28"/></VBox.margin>
        </Label>

        <Label text="Email address" styleClass="field-label">
            <VBox.margin><Insets bottom="6"/></VBox.margin>
        </Label>
        <TextField fx:id="emailField"
                   promptText="you@esprit.tn"
                   styleClass="input-field">
            <VBox.margin><Insets bottom="12"/></VBox.margin>
        </TextField>

        <Label fx:id="messageLabel" text="" wrapText="true" styleClass="muted-text">
            <VBox.margin><Insets bottom="16"/></VBox.margin>
        </Label>

        <Button text="Send reset code"
                maxWidth="Infinity"
                onAction="#handleSendResetMail"
                styleClass="btn-primary">
            <VBox.margin><Insets bottom="12"/></VBox.margin>
        </Button>

        <HBox alignment="CENTER_LEFT" spacing="6">
            <Hyperlink text="← Back to login"
                       onAction="#handleBackToLogin"
                       styleClass="link-blue-bold"/>
        </HBox>

    </VBox>

</AnchorPane>

